---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import CopyAsMarkdown from "@/components/foundations/scripts/CopyAsMarkdown.astro";
import ToCScript from "@/components/foundations/scripts/ToCScript.astro";

interface Props {
  title?: string;
  description?: string;
  navItems: CollectionEntry<"docs">[];
}

const { title, description, navItems } = Astro.props;

const resolvedNavLinks = navItems.map((item) => ({
  href: item.id === "overview" ? "/docs" : `/docs/${item.id}`,
  label: item.data.navLabel ?? item.data.title,
  category: item.data.category ?? "Docs",
}));

const groupedNavLinks = resolvedNavLinks.reduce(
  (groups, item) => {
    const existing = groups.find((group) => group.category === item.category);
    if (existing) {
      existing.items.push(item);
      return groups;
    }
    groups.push({ category: item.category, items: [item] });
    return groups;
  },
  [] as { category: string; items: typeof resolvedNavLinks }[],
);
---

<BaseLayout title={title} description={description}>
  <div
    class="mx-auto grid w-full max-w-7xl grid-cols-1 gap-10 px-6 py-12 lg:grid-cols-[13rem_minmax(0,1fr)] lg:py-16 xl:grid-cols-[13rem_minmax(0,1fr)_14rem]"
  >
    <aside class="hidden w-52 shrink-0 lg:block">
      <nav class="sticky top-20 flex flex-col gap-5">
        {
          groupedNavLinks.map((group) => (
            <div>
              <p class="text-muted-foreground px-3 text-xs font-medium tracking-wide uppercase">
                {group.category}
              </p>
              <div class="mt-2 flex flex-col gap-1">
                {group.items.map((item) => (
                  <a
                    href={item.href}
                    class:list={[
                      "rounded-lg px-3 py-1.5 text-sm transition-colors",
                      Astro.url.pathname.replace(/\/$/, "") ===
                      item.href.replace(/\/$/, "")
                        ? "bg-secondary text-foreground"
                        : "text-muted-foreground hover:text-foreground",
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </nav>
    </aside>
    <div class="space-y-8 xl:hidden">
      <div class="flex flex-wrap gap-2">
        <button
          data-copy-markdown
          type="button"
          class="border-border bg-background text-foreground hover:bg-secondary rounded-lg border px-3 py-1.5 text-sm transition-colors"
        >
          Copy page as Markdown
        </button>
      </div>
      <nav
        aria-label="Table of contents"
        class="border-border rounded-lg border p-4"
      >
        <p
          class="text-muted-foreground text-xs font-medium tracking-wide uppercase"
        >
          On this page
        </p>
        <ol data-toc-list role="list" class="mt-3 flex flex-col gap-2">
          <li data-toc-empty class="text-muted-foreground text-xs/5">
            No sections on this page.
          </li>
        </ol>
      </nav>
    </div>
    <article
      id="markdown-content"
      class="prose prose-neutral dark:prose-invert max-w-none min-w-0 flex-1"
    >
      <slot />
    </article>
    <aside class="hidden xl:block">
      <div class="sticky top-20 space-y-8">
        <div>
          <p
            class="text-muted-foreground px-3 text-xs font-medium tracking-wide uppercase"
          >
            Actions
          </p>
          <div class="mt-2 flex flex-col gap-2">
            <button
              data-copy-markdown
              type="button"
              class="border-border bg-background text-foreground hover:bg-secondary rounded-lg border px-3 py-1.5 text-left text-sm transition-colors"
            >
              Copy page as Markdown
            </button>
          </div>
        </div>
        <nav aria-label="Table of contents">
          <p
            class="text-muted-foreground px-3 text-xs font-medium tracking-wide uppercase"
          >
            On this page
          </p>
          <ol data-toc-list role="list" class="mt-3 flex flex-col gap-2 px-3">
            <li data-toc-empty class="text-muted-foreground text-xs/5">
              No sections on this page.
            </li>
          </ol>
        </nav>
      </div>
    </aside>
  </div>
  <CopyAsMarkdown />
  <ToCScript />
</BaseLayout>
