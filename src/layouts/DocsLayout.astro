---
import Text from "@/components/foundations/elements/Text.astro";
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "@/components/ui/sidebar";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import type { CollectionEntry } from "astro:content";
import ToCScript from "@/components/foundations/scripts/ToCScript.astro";
import TableOfContents from "@/components/foundations/navigation/TableOfContents.astro";
import type { JsonLdBreadcrumb } from "@/lib/seo/json-ld";

interface Props {
  title?: string;
  description?: string;
  navItems: CollectionEntry<"docs">[];
}

const { title, description, navItems } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const displayTitle = title?.replace(/\s+— Kobbe Docs$/, "");

const resolvedNavLinks = navItems.map((item) => ({
  href: item.id === "overview" ? "/docs" : `/docs/${item.id}`,
  label: item.data.navLabel ?? item.data.title,
  category: item.data.category ?? "Docs",
  isActive:
    currentPath ===
    (item.id === "overview" ? "/docs" : `/docs/${item.id}`).replace(/\/$/, ""),
}));

const groupedNavLinks = resolvedNavLinks.reduce(
  (groups, item) => {
    const existing = groups.find((group) => group.category === item.category);
    if (existing) {
      existing.items.push(item);
      return groups;
    }
    groups.push({ category: item.category, items: [item] });
    return groups;
  },
  [] as { category: string; items: typeof resolvedNavLinks }[],
);
const currentNavLink = resolvedNavLinks.find((item) => item.isActive);
const jsonLdBreadcrumbs: JsonLdBreadcrumb[] =
  currentPath === "/docs"
    ? [{ name: "Docs", item: "/docs" }]
    : [
        { name: "Docs", item: "/docs" },
        {
          name: currentNavLink?.label ?? displayTitle ?? "Docs",
          item: currentNavLink?.href ?? currentPath,
        },
      ];

/** Stable sidebar order so Dashboard stats sits under Get started (not after long guide groups). */
const NAV_GROUP_ORDER = [
  "Get started",
  "Dashboard stats",
  "Installation guides",
  "Tracking",
  "Analyze",
  "Sharing",
  "Revenue attribution",
  "Manage",
  "Support",
  "Legal",
  "Docs",
] as const;

groupedNavLinks.sort((a, b) => {
  const ai = NAV_GROUP_ORDER.indexOf(
    a.category as (typeof NAV_GROUP_ORDER)[number],
  );
  const bi = NAV_GROUP_ORDER.indexOf(
    b.category as (typeof NAV_GROUP_ORDER)[number],
  );
  const ar = ai === -1 ? NAV_GROUP_ORDER.length : ai;
  const br = bi === -1 ? NAV_GROUP_ORDER.length : bi;
  return ar - br || a.category.localeCompare(b.category);
});
---

<BaseLayout
  title={title}
  description={description}
  jsonLdBreadcrumbs={jsonLdBreadcrumbs}
  docsNavGroups={groupedNavLinks}
>
  <Wrapper variant="default">
    <div
      class="grid w-full grid-cols-1 gap-10 py-12 lg:grid-cols-[16rem_minmax(0,1fr)] xl:grid-cols-[16rem_minmax(0,1fr)_14rem]"
    >
      <Sidebar client:load groups={groupedNavLinks} />
      <Wrapper
        variant="prose"
        id="markdown-content"
        class="max-w-none min-w-0 flex-1"
      >
        {
          displayTitle && (
            <header class="not-prose flex w-full max-w-2xl items-start justify-between gap-4">
              <div class="min-w-0">
                <Text
                  tag="h1"
                  variant="displayXS"
                  class="text-foreground font-medium tracking-tight"
                >
                  {displayTitle}
                </Text>
                {description && (
                  <Text
                    tag="h1"
                    variant="textBase"
                    class="text-muted-foreground mt-2"
                  >
                    {description}
                  </Text>
                )}
              </div>
              <div class="mt-1 ml-auto w-fit shrink-0">
                <slot name="header-actions" />
              </div>
            </header>
          )
        }
        <slot />
      </Wrapper>
      <TableOfContents />
    </div>
  </Wrapper>
  <ToCScript />
</BaseLayout>
