---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  title?: string;
  description?: string;
  navItems: CollectionEntry<"docs">[];
}

const { title, description, navItems } = Astro.props;

const resolvedNavLinks = navItems.map((item) => ({
  href: item.id === "overview" ? "/docs" : `/docs/${item.id}`,
  label: item.data.navLabel ?? item.data.title,
}));
---

<BaseLayout title={title} description={description}>
  <div
    class="mx-auto flex w-full max-w-6xl gap-0 px-6 py-12 lg:gap-10 lg:py-16"
  >
    <aside class="hidden w-52 shrink-0 lg:block">
      <nav class="sticky top-20 flex flex-col gap-1">
        {
          resolvedNavLinks.map((item) => (
            <a
              href={item.href}
              class:list={[
                "rounded-lg px-3 py-1.5 text-sm transition-colors",
                Astro.url.pathname.replace(/\/$/, "") ===
                item.href.replace(/\/$/, "")
                  ? "bg-secondary text-foreground font-medium"
                  : "text-muted-foreground hover:text-foreground",
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </aside>
    <article
      class="prose prose-neutral dark:prose-invert max-w-none min-w-0 flex-1"
    >
      <slot />
    </article>
  </div>
</BaseLayout>
