---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
  description?: string;
  /** Omit the prose wrapper for custom layouts (e.g. DPA generator + clauses). */
  bare?: boolean;
}

const { title, description, bare = false } = Astro.props;
---

<BaseLayout
  title={title ? `${title} — Kobbe` : "Kobbe"}
  description={description}
>
  <div class="mx-auto max-w-3xl px-6 py-12 lg:py-16">
    {
      bare ? (
        <slot />
      ) : (
        <article class="prose prose-neutral dark:prose-invert max-w-none">
          <slot />
        </article>
      )
    }
  </div>
</BaseLayout>
