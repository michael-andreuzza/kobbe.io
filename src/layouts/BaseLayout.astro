---
import "@/styles/global.css";
import Navigation from "@/components/global/Navigation.astro";
import Footer from "@/components/global/Footer.astro";
import SiteSeo from "@/components/foundations/head/SiteSeo.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageHeight?: number;
  ogImageWidth?: number;
  twitterImage?: string;
  ogType?: string;
  noindex?: boolean;
  nofollow?: boolean;
  jsonLdExtra?: Record<string, unknown>[];
  hideNavigation?: boolean;
  hideFooter?: boolean;
  docsNavGroups?: {
    category: string;
    items: { href: string; label: string; isActive: boolean }[];
  }[];
}

const {
  title = "Kobbe — Web analytics that respect your visitors",
  description = "Privacy-friendly, cookie-free website analytics. See your traffic, top pages, referrers, locations, and devices in a clean dashboard.",
  canonical,
  ogImage,
  ogImageAlt,
  ogImageHeight,
  ogImageWidth,
  twitterImage,
  ogType,
  noindex,
  nofollow,
  jsonLdExtra,
  hideNavigation = false,
  hideFooter = false,
  docsNavGroups,
} = Astro.props;
---

<html lang="en">
  <head>
    <SiteSeo
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogImageHeight={ogImageHeight}
      ogImageWidth={ogImageWidth}
      twitterImage={twitterImage}
      ogType={ogType}
      noindex={noindex}
      nofollow={nofollow}
      jsonLdExtra={jsonLdExtra}
    />
    <script
      is:inline
      src="https://app.kobbe.io/tracker.full.js"
      data-token="996f51cb.0EZHVIaNsKiNLpfqBR_RmtZ0jj_obT4O"
      data-revenue-attribution="true"
      data-performance="true"
      defer></script>
  </head>
  <body class="bg-background flex min-h-svh flex-col antialiased">
    {!hideNavigation && <Navigation docsNavGroups={docsNavGroups} />}
    <main class="isolate grow">
      <slot />
    </main>
    {!hideFooter && <Footer />}
  </body>
</html>
