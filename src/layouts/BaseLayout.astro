---
import "@/styles/global.css";
import Navigation from "@/components/global/Navigation.astro";
import Footer from "@/components/global/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  hideNavigation?: boolean;
  hideFooter?: boolean;
}

const {
  title = "Kobbe — Web analytics that respect your visitors",
  description = "Privacy-friendly, cookie-free website analytics. See your traffic, top pages, referrers, locations, and devices in a clean dashboard.",
  hideNavigation = false,
  hideFooter = false,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      (function () {
        try {
          var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
          document.documentElement.style.colorScheme = dark ? "dark" : "light";
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="flex min-h-svh flex-col antialiased">
    {!hideNavigation && <Navigation />}
    <main class="isolate grow">
      <slot />
    </main>
    {!hideFooter && <Footer />}
  </body>
</html>
