---
import BaseLayout from "@/layouts/BaseLayout.astro";

const supportEmail = "support@kobbe.io";
---

<BaseLayout
  title="Support — Kobbe"
  description="Get help with Kobbe setup, billing, privacy-friendly analytics, and workspace questions."
>
  <section class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <p
      class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
    >
      Support
    </p>
    <h1
      class="text-foreground mt-4 text-4xl font-semibold tracking-tight text-balance sm:text-5xl"
    >
      Need help with Kobbe?
    </h1>
    <p class="text-muted-foreground mt-5 max-w-2xl text-base/7 text-pretty">
      Send us a note and we will help with setup, billing, privacy questions,
      revenue attribution, or anything else around your workspace.
    </p>

    <div class="border-border/70 bg-card mt-10 rounded-xl border p-5">
      <p class="text-foreground text-sm font-medium">Email support</p>
      <p class="text-muted-foreground mt-2 text-sm/6">
        We usually reply as soon as possible during normal working hours.
      </p>
      <a
        href={`mailto:${supportEmail}`}
        class="bg-foreground text-background hover:bg-foreground/90 mt-5 inline-flex items-center justify-center rounded-lg px-4 py-2.5 text-sm font-medium transition-colors"
      >
        {supportEmail}
      </a>
    </div>
  </section>
</BaseLayout>
