---
import LegalLayout from "@/layouts/LegalLayout.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("legal", "dpa");
if (!entry) {
  throw new Error('Missing content collection entry "legal/dpa"');
}
const { Content } = await render(entry);

const effectiveDateDefault = new Date().toISOString().slice(0, 10);

const pageTitle = "Data processing agreement";
const pageDescription = entry.data.description;
---

<LegalLayout title={pageTitle} description={pageDescription} bare>
  <div class="no-print mb-10 space-y-6 rounded-lg border border-border/60 bg-card/40 px-4 py-5 sm:px-5">
    <div class="space-y-1">
      <h1 class="text-foreground text-2xl font-semibold tracking-tight">
        {pageTitle}
      </h1>
      <p class="text-muted-foreground text-sm leading-relaxed">
        Part of our <a
          href="/legal/terms"
          class="text-foreground underline decoration-border underline-offset-2 hover:decoration-foreground"
          >Terms</a
        >. Using the hosted service at
        <a
          href="https://app.kobbe.io"
          class="text-foreground underline decoration-border underline-offset-2 hover:decoration-foreground"
          >app.kobbe.io</a
        >
        accepts this DPA as posted here. Optionally add your details and use <strong>Download PDF</strong> → Save as
        PDF for records only.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block space-y-1.5 sm:col-span-2">
        <span class="text-foreground text-xs font-medium">Customer legal name</span>
        <input
          id="dpa-in-company"
          type="text"
          autocomplete="organization"
          placeholder="Example Corp Oy"
          class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:ring-ring w-full rounded-md border px-3 py-2 text-sm shadow-sm focus-visible:ring-2 focus-visible:outline-none"
        />
      </label>
      <label class="block space-y-1.5">
        <span class="text-foreground text-xs font-medium">Signatory name</span>
        <input
          id="dpa-in-name"
          type="text"
          autocomplete="name"
          placeholder="Jane Doe"
          class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:ring-ring w-full rounded-md border px-3 py-2 text-sm shadow-sm focus-visible:ring-2 focus-visible:outline-none"
        />
      </label>
      <label class="block space-y-1.5">
        <span class="text-foreground text-xs font-medium">Signatory title</span>
        <input
          id="dpa-in-title"
          type="text"
          autocomplete="organization-title"
          placeholder="Founder"
          class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:ring-ring w-full rounded-md border px-3 py-2 text-sm shadow-sm focus-visible:ring-2 focus-visible:outline-none"
        />
      </label>
      <label class="block space-y-1.5 sm:col-span-2">
        <span class="text-foreground text-xs font-medium">Country / region</span>
        <input
          id="dpa-in-country"
          type="text"
          autocomplete="country-name"
          placeholder="Finland"
          class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:ring-ring w-full rounded-md border px-3 py-2 text-sm shadow-sm focus-visible:ring-2 focus-visible:outline-none"
        />
      </label>
      <label class="block space-y-1.5 sm:col-span-2">
        <span class="text-foreground text-xs font-medium">Address</span>
        <textarea
          id="dpa-in-address"
          rows={2}
          autocomplete="street-address"
          placeholder="Street, city, postal code"
          class="border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:ring-ring w-full resize-y rounded-md border px-3 py-2 text-sm shadow-sm focus-visible:ring-2 focus-visible:outline-none"
        ></textarea>
      </label>
      <label class="block space-y-1.5">
        <span class="text-foreground text-xs font-medium">Effective date</span>
        <input
          id="dpa-in-date"
          type="date"
          value={effectiveDateDefault}
          class="border-input bg-background text-foreground focus-visible:ring-ring w-full rounded-md border px-3 py-2 text-sm shadow-sm focus-visible:ring-2 focus-visible:outline-none"
        />
      </label>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <button
        type="button"
        id="dpa-print-btn"
        class="bg-foreground text-background hover:bg-foreground/90 focus-visible:ring-ring inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium shadow-sm transition-colors focus-visible:ring-2 focus-visible:outline-none"
      >
        Download PDF
      </button>
      <p class="text-muted-foreground text-xs">
        PDF is optional (for records or procurement). Involve your counsel for enterprise reviews if needed.
      </p>
    </div>
  </div>

  <div id="dpa-printable">
    <div
      class="border-border/60 text-foreground mb-8 space-y-3 rounded-lg border bg-card/30 px-4 py-5 text-sm leading-relaxed sm:px-5"
    >
      <p class="text-muted-foreground text-xs font-medium uppercase tracking-wide">
        Kobbe — data processing addendum
      </p>
      <p>
        <strong>How this DPA applies:</strong> It is part of Kobbe’s
        <a href="/legal/terms">Terms of Service</a>. Using the hosted Service at
        <a href="https://app.kobbe.io">app.kobbe.io</a> after this version is published typically
        <strong>accepts</strong> this DPA online, as described in Section 18. The fields you complete below are for
        <strong>identification and PDF records</strong>; they do not replace the Terms.
      </p>
      <p>
        <strong>Your legal review:</strong> Organizations may involve their own counsel for procurement or
        regulatory review. Kobbe may update schedules in this document (for example sub‑processors or retention);
        the version at this URL is controlling unless you have a separate written agreement with Kobbe.
      </p>
      <p>
        <strong>Scope:</strong> Vendor‑hosted Kobbe only. Self‑hosted deployments should use a different
        agreement.
      </p>
      <p>
        This Data Processing Addendum (&quot;DPA&quot;) is entered into between <strong>Kobbe</strong>
        (&quot;Company&quot;), operated by <strong>Michael Alexandert Web Agency, trading as Kobbe</strong>,
        Riåkervägen 2, Sviby, Åland Islands, Finland, as processor for the hosted analytics service at
        <a href="https://app.kobbe.io">app.kobbe.io</a>) and <span id="dpa-out-company" class="font-medium"
          >____________________________</span
        >
        (&quot;Customer&quot;) for use of the Kobbe analytics platform (&quot;Service&quot;).
      </p>
      <ul class="list-inside list-disc space-y-1 text-sm">
        <li>
          <span class="text-muted-foreground">Signatory:</span>
          <span id="dpa-out-name" class="font-medium">____________________________</span>
          <span class="text-muted-foreground">,</span>
          <span id="dpa-out-title" class="font-medium">____________________________</span>
        </li>
        <li>
          <span class="text-muted-foreground">Country / region:</span>
          <span id="dpa-out-country" class="font-medium">____________________________</span>
        </li>
        <li>
          <span class="text-muted-foreground">Address:</span>
          <span id="dpa-out-address" class="font-medium whitespace-pre-wrap">____________________________</span>
        </li>
        <li>
          <span class="text-muted-foreground">Effective date:</span>
          <span id="dpa-out-date" class="font-medium">{effectiveDateDefault}</span>
        </li>
      </ul>
    </div>

    <article class="prose prose-neutral dark:prose-invert max-w-none">
      <Content />
    </article>
  </div>
</LegalLayout>

<style is:global>
  @media print {
    .no-print {
      display: none !important;
    }
    header[class*="sticky"],
    header.sticky,
    body > footer {
      display: none !important;
    }
    main {
      display: block !important;
    }
    body {
      background: white !important;
    }
    :global(.dark) body {
      background: white !important;
    }
    #dpa-printable {
      color: #111 !important;
    }
    #dpa-printable a {
      color: #111 !important;
      text-decoration: none !important;
    }
  }
</style>

<script is:inline>
  (function () {
    const placeholder = "____________________________";

    function read(id) {
      var el = document.getElementById(id);
      return el && "value" in el ? String(el.value || "").trim() : "";
    }

    function setText(id, value, usePlaceholder) {
      var el = document.getElementById(id);
      if (!el) return;
      var t = value || (usePlaceholder ? placeholder : "—");
      el.textContent = t;
    }

    function sync() {
      setText("dpa-out-company", read("dpa-in-company"), true);
      setText("dpa-out-name", read("dpa-in-name"), true);
      setText("dpa-out-title", read("dpa-in-title"), true);
      setText("dpa-out-country", read("dpa-in-country"), true);
      setText("dpa-out-address", read("dpa-in-address"), true);
      var dateVal = read("dpa-in-date");
      setText("dpa-out-date", dateVal, false);
    }

    function init() {
      var inputs = [
        "dpa-in-company",
        "dpa-in-name",
        "dpa-in-title",
        "dpa-in-country",
        "dpa-in-address",
        "dpa-in-date",
      ];
      for (var i = 0; i < inputs.length; i++) {
        var node = document.getElementById(inputs[i]);
        if (!node) continue;
        node.addEventListener("input", sync);
        node.addEventListener("change", sync);
      }
      var btn = document.getElementById("dpa-print-btn");
      if (btn)
        btn.addEventListener("click", function () {
          sync();
          window.print();
        });
      sync();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
