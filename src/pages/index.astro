---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pricing from "@/components/sections/Pricing.astro";

const showFullLanding = false;
---

<BaseLayout
  title="Kobbe — Web analytics that respect your visitors"
  description="Privacy-friendly, cookie-free website analytics. See your traffic, top pages, referrers, locations, and devices in a clean dashboard without building invasive visitor profiles."
  hideNavigation
  hideFooter
>
  <section class="mx-auto flex min-h-[calc(100svh-9rem)] max-w-6xl items-center px-6 py-20 lg:py-28">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-muted-foreground text-sm ">
        Coming soon
      </p>
      <h1
        class="text-foreground mt-4  text-4xl font-semibold tracking-tight text-balance "
      >
        Kobbe is getting ready to launch.
      </h1>
      <p class="text-muted-foreground mt-4  text-base text-balance">
        Privacy-friendly analytics and revenue tracking for people who want clear traffic insights
        without invasive visitor tracking. We are polishing the product before
        opening access.
      </p>
    
      
    </div>
  </section>

  {
    showFullLanding ? (
      <>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-6 pt-20 lg:pt-28">
    <div class="max-w-2xl">
      <p
        class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
      >
        Privacy-friendly analytics
      </p>
      <h1
        class="text-foreground mt-4 max-w-[24ch] text-4xl font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl"
      >
        Know your traffic. Respect your visitors.
      </h1>
      <p
        class="text-muted-foreground mt-6 max-w-[48ch] text-lg/7 text-pretty sm:text-base/7"
      >
        Lightweight, cookie-free website analytics with a clean dashboard. See
        visitors, top pages, referrers, locations, and devices without
        compromising privacy.
      </p>
      <p class="text-muted-foreground mt-4 max-w-[52ch] text-sm/6 text-pretty">
        Revenue attribution is available as an opt-in setup, designed around
        pseudonymous attribution keys instead of invasive visitor profiles.
      </p>
    </div>

    <div
      class="border-border/70 bg-card mt-12 overflow-hidden rounded-xl border shadow-xs lg:mt-16"
    >
      <div
        class="border-border/70 flex items-center gap-2 border-b px-4 py-2.5"
      >
        <span class="bg-border size-3 rounded-full"></span>
        <span class="bg-border size-3 rounded-full"></span>
        <span class="bg-border size-3 rounded-full"></span>
        <span
          class="text-muted-foreground ml-3 flex-1 truncate text-xs tabular-nums"
          >app.kobbe.io</span
        >
      </div>
      <iframe
        src="https://app.kobbe.io/share/share_782c5241a5d1964e3c734ff27e76050d"
        title="Live Kobbe dashboard demo"
        loading="lazy"
        class="h-[32rem] w-full lg:h-[40rem]"
        sandbox="allow-scripts allow-same-origin"></iframe>
    </div>
  </section>

  <!-- Metrics strip -->
  <section class="border-border/60 mt-24 border-t lg:mt-32">
    <div
      class="mx-auto grid max-w-6xl grid-cols-2 gap-px px-6 py-16 sm:grid-cols-4 lg:py-20"
    >
      <div class="pr-6 sm:pr-8">
        <p class="text-muted-foreground text-sm">Tracker size</p>
        <p class="text-foreground mt-1 text-2xl font-semibold tabular-nums">
          &lt; 1 KB
        </p>
      </div>
      <div class="pl-6 sm:border-border/60 sm:border-l sm:pl-8">
        <p class="text-muted-foreground text-sm">Cookies used</p>
        <p class="text-foreground mt-1 text-2xl font-semibold tabular-nums">
          0
        </p>
      </div>
      <div
        class="border-border/60 mt-8 border-t pt-8 sm:mt-0 sm:border-t-0 sm:border-l sm:pt-0 sm:pl-8"
      >
        <p class="text-muted-foreground text-sm">Raw IPs stored</p>
        <p class="text-foreground mt-1 text-2xl font-semibold tabular-nums">
          0
        </p>
      </div>
      <div
        class="border-border/60 mt-8 border-t pt-8 pl-6 sm:mt-0 sm:border-t-0 sm:border-l sm:pt-0 sm:pl-8"
      >
        <p class="text-muted-foreground text-sm">Privacy posture</p>
        <p class="text-foreground mt-1 text-2xl font-semibold tabular-nums">
          Minimal
        </p>
      </div>
    </div>
  </section>

  <!-- Dashboard capabilities -->
  <section class="border-border/60 border-t">
    <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
      <p
        class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
      >
        Your dashboard
      </p>
      <h2
        class="text-foreground mt-3 max-w-[35ch] text-2xl font-semibold tracking-tight sm:text-3xl"
      >
        Everything you need to understand your audience.
      </h2>
      <p class="text-muted-foreground mt-4 max-w-[56ch] text-base/7">
        A single, focused dashboard gives you the full picture of who visits
        your sites, where they come from, and what they look at.
      </p>

      <dl
        class="mt-12 grid gap-8 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3 lg:gap-x-12 lg:gap-y-10"
      >
        <div>
          <dt class="text-foreground text-sm font-medium">
            Real-time visitors
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            See who is on your site right now with a live counter and active
            page list.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Pages and entry/exit paths
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Top pages, entry pages, and exit pages so you know what content
            attracts and retains visitors.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Referrers and channels
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Traffic sources broken down by referrer, search engine, social
            network, and direct visits.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Countries, regions, and cities
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Geographic breakdown of your audience without collecting IP
            addresses or personal data.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Browsers, OS, and devices
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Know which browsers and devices your visitors use so you can
            prioritize what to support.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">Custom events</dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Track sign-ups, clicks, form submissions, or any interaction that
            matters to your business.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Built-in bot filtering
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Bots, referrer spam, and data-center traffic are automatically
            excluded so your stats reflect real humans.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            AI traffic monitoring
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            See which AI tools like ChatGPT, Perplexity, or Claude send you
            traffic and which pages they visit.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Shareable dashboard links
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Generate public, read-only links for clients or teammates and
            manage access from site settings.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Funnels and revenue
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Measure conversion steps and optionally connect payment webhooks to
            see which traffic turns into revenue.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">CSV export</dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Download your site events for reporting, backups, or analysis in a
            spreadsheet.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-border/60 bg-surface border-t">
    <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
      <p
        class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
      >
        How it works
      </p>
      <h2
        class="text-foreground mt-3 max-w-[35ch] text-2xl font-semibold tracking-tight sm:text-3xl"
      >
        Three steps to better insights.
      </h2>

      <dl class="mt-12 grid gap-8 sm:grid-cols-3 lg:mt-16 lg:gap-12">
        <div>
          <dt class="text-foreground text-sm font-medium">
            <span
              class="text-muted-foreground mr-2 inline-flex size-6 items-center justify-center rounded-full border text-xs tabular-nums"
              >1</span
            >
            Add the script
          </dt>
          <dd class="text-muted-foreground mt-3 text-sm/6">
            Drop a single, lightweight script tag on your site. It loads
            asynchronously and is designed to stay out of the critical path.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            <span
              class="text-muted-foreground mr-2 inline-flex size-6 items-center justify-center rounded-full border text-xs tabular-nums"
              >2</span
            >
            Collect visits and events
          </dt>
          <dd class="text-muted-foreground mt-3 text-sm/6">
            Page views, custom events, referrers, and device data start flowing
            in immediately with no analytics cookies. Consent requirements still
            depend on your setup and jurisdiction.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            <span
              class="text-muted-foreground mr-2 inline-flex size-6 items-center justify-center rounded-full border text-xs tabular-nums"
              >3</span
            >
            Read your dashboard
          </dt>
          <dd class="text-muted-foreground mt-3 text-sm/6">
            Open your Kobbe dashboard to see real-time stats, traffic trends,
            top pages, sources, and locations at a glance.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Privacy and performance -->
  <section class="border-border/60 border-t">
    <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
      <p
        class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
      >
        Privacy and performance
      </p>
      <h2
        class="text-foreground mt-3 max-w-[35ch] text-2xl font-semibold tracking-tight sm:text-3xl"
      >
        Analytics without the trade-offs.
      </h2>
      <p class="text-muted-foreground mt-4 max-w-[56ch] text-base/7">
        No cookies, no persistent visitor profiles, and no raw IP storage.
        Kobbe gives you useful traffic insights while keeping your visitors'
        privacy intact.
      </p>

      <dl
        class="mt-12 grid gap-8 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3 lg:gap-x-12 lg:gap-y-10"
      >
        <div>
          <dt class="text-foreground text-sm font-medium">Cookie-free</dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            The default tracker uses no cookies, localStorage, or persistent
            browser identifiers.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Lightweight tracker
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            The script is under 1 KB, loads async, and is designed to stay out
            of the critical rendering path.
          </dd>
        </div>
        <div>
          <dt class="text-foreground text-sm font-medium">
            Privacy-aware attribution
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Optional revenue attribution uses session-scoped, pseudonymous
            keys. You stay in control of when to enable it and how to disclose
            it.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <Pricing />

  <!-- FAQ -->
  <section class="border-border/60 border-t">
    <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
      <h2
        class="text-foreground text-2xl font-semibold tracking-tight sm:text-3xl"
      >
        Frequently asked questions.
      </h2>

      <dl
        class="border-border/60 mt-12 divide-y lg:mt-16"
        style="--tw-divide-opacity: 0.6"
      >
        <div class="py-6 first:pt-0 last:pb-0">
          <dt class="text-foreground text-sm font-medium">
            Do I need a cookie banner?
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Kobbe's default tracker does not use cookies or persistent browser
            identifiers. Consent rules still depend on your jurisdiction,
            configuration, and whether you enable optional features such as
            revenue attribution.
          </dd>
        </div>
        <div class="py-6 first:pt-0 last:pb-0">
          <dt class="text-foreground text-sm font-medium">
            How does Kobbe count unique visitors without cookies?
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Kobbe uses a privacy-safe hashing method that generates a daily,
            non-reversible identifier from anonymized request data. It cannot
            track individuals across days or sites.
          </dd>
        </div>
        <div class="py-6 first:pt-0 last:pb-0">
          <dt class="text-foreground text-sm font-medium">
            Are bots counted in my stats?
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            No. Kobbe has built-in bot filtering that excludes crawlers,
            referrer spam, and data-center traffic automatically.
          </dd>
        </div>
        <div class="py-6 first:pt-0 last:pb-0">
          <dt class="text-foreground text-sm font-medium">
            Can I share my dashboard with clients?
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            Yes. You can generate public, read-only dashboard links from your
            site settings and revoke them at any time.
          </dd>
        </div>
        <div class="py-6 first:pt-0 last:pb-0">
          <dt class="text-foreground text-sm font-medium">
            Will the script slow down my site?
          </dt>
          <dd class="text-muted-foreground mt-2 text-sm/6">
            It is designed not to. The tracker is under 1 KB, loads
            asynchronously, and avoids blocking the critical rendering path.
          </dd>
        </div>
      </dl>
    </div>
  </section>
      </>
    ) : null
  }
</BaseLayout>
