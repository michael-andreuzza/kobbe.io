---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/landing/Hero.astro";
import HowItWorks from "@/components/landing/HowItWorks.astro";
import DashboardCapabilities from "@/components/landing/DashboardCapabilities.astro";
import RevenueInsights from "@/components/landing/RevenueInsights.astro";
import FunnelInsights from "@/components/landing/FunnelInsights.astro";
import UtmCampaigns from "@/components/landing/UtmCampaigns.astro";
import PerformanceInsights from "@/components/landing/PerformanceInsights.astro";
import CliAgents from "@/components/landing/CliAgents.astro";
import PricingSection from "@/components/sections/pricing/Pricing.astro";
import FaqSection from "@/components/landing/FaqSection.astro";
import AllFeatures from "@/components/landing/AllFeatures.astro";
import {
  buildPricingJsonLdOffers,
  pricingTiers,
} from "@/components/sections/pricing/pricing-tiers";

const pricingJsonLd = [
  {
    "@type": "SoftwareApplication",
    "@id": "https://kobbe.io/#software",
    name: "Kobbe",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://kobbe.io",
    description:
      "Website analytics pricing from $15.99/month with 1M monthly events. Event-based plans with cookie-free tracking, privacy-friendly insights, and every feature included.",
    offers: {
      "@type": "AggregateOffer",
      lowPrice: "8.99",
      highPrice: "470.99",
      priceCurrency: "USD",
      offerCount: String(pricingTiers.length),
      url: "https://kobbe.io/#pricing",
      offers: buildPricingJsonLdOffers("https://kobbe.io/#pricing"),
    },
    publisher: { "@id": "https://kobbe.io/#organization" },
  },
];
---

<BaseLayout
  title="Kobbe — Web analytics that respect your visitors"
  description="Privacy-friendly, cookie-free website analytics for traffic, pages, referrers, locations, devices, custom events, and revenue insights."
  jsonLdExtra={pricingJsonLd}
>
  <Hero />
  <DashboardCapabilities />
  <AllFeatures />
  <RevenueInsights />
  <FunnelInsights />
  <UtmCampaigns />
  <PerformanceInsights />
  <CliAgents />
  <HowItWorks />
  <PricingSection />
  <FaqSection />
</BaseLayout>
