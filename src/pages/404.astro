---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not found — Kobbe" noindex nofollow hideFooter>
  <div
    class="flex min-h-[60vh] flex-col items-center justify-center px-6 text-center"
  >
    <p class="text-foreground text-6xl font-semibold">404</p>
    <p class="text-muted-foreground mt-4">
      The page you're looking for doesn't exist.
    </p>
    <a
      href="/"
      class="text-foreground hover:text-muted-foreground mt-8 text-sm font-medium underline underline-offset-4"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
