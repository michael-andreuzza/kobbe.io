---
import BaseLayout from "@/layouts/BaseLayout.astro"
---

<BaseLayout title="Not found — Kobbe" hideFooter>
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-6 text-center">
    <p class="text-6xl font-semibold text-foreground">404</p>
    <p class="mt-4 text-muted-foreground">The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="mt-8 text-sm font-medium text-foreground underline underline-offset-4 hover:text-muted-foreground"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
