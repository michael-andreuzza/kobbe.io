---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import Text from "@/components/foundations/elements/Text.astro";
import FooterLogoReveal from "@/components/global/footer-logo-reveal";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";

type FooterLink = {
  href: string;
  label: string;
  target?: string;
  rel?: string;
};

type FooterLinkGroup = {
  title: string;
  links: FooterLink[];
};

const footerLinkGroups: FooterLinkGroup[] = [
  {
    title: "Product",
    links: [
      { href: "/#benefits", label: "Features" },
      { href: "/#pricing", label: "Pricing" },
      { href: "/docs", label: "Docs" },
      { href: "/llms.txt", label: "llms.txt" },
    ],
  },
  {
    title: "Support",
    links: [
      { href: "/docs/support-contact", label: "Contact" },
      { href: "/docs/support-faq", label: "FAQ" },
      { href: "/docs/support-charges", label: "Charges" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/docs/legal-terms", label: "Terms" },
      { href: "/docs/legal-privacy", label: "Privacy" },
      { href: "/docs/legal-gdpr-compliance", label: "GDPR" },
      { href: "/docs/legal-dpa", label: "DPA" },
    ],
  },
  {
    title: "More",
    links: [
      {
        href: "http://lexingtonthemes.com/",
        label: "Astro Website templates",
        target: "_blank",
        rel: "noopener noreferrer",
      },
    ],
  },
];
---

<footer class="overflow-x-clip pt-20">
  <Wrapper variant="default">
    <div class="mx-auto max-w-4xl">
      <div class="max-w-md text-balance lg:mx-auto lg:text-center">
        <div class="lg:col-span-2">
          <Text
            tag="h2"
            variant="textXL"
            class="text-foreground font-medium text-balance"
          >
            Set up in 5 minutes. <br /> Back to marketing by <span
              data-setup-time>soon</span
            >.
          </Text>
          <Text
            tag="p"
            variant="textBase"
            class="text-muted-foreground font-medium text-balance"
          >
            Privacy-friendly analytics for teams that want clear numbers without
            extra tracking work.
          </Text>
        </div>

        <a
          href="/#pricing"
          data-kobbe-event="Footer CTA — start free trial"
          class={cn(
            buttonVariants({ variant: "default", size: "sm" }),
            "lg:ml-auto w-fit mt-8 mx-auto",
          )}
        >
          Start a free trial
        </a>
      </div>

      <div class="border-border/60 mt-8 w-full border-t pt-8">
        <p class="text-foreground text-sm font-semibold uppercase">
          &copy; {new Date().getFullYear()} Kobbe. All rights reserved.
        </p>
        <nav
          class="mt-8 grid grid-cols-2 gap-8 text-sm md:grid-cols-4 lg:col-start-3"
        >
          {
            footerLinkGroups.map((group) => (
              <div class="space-y-3">
                <Text
                  tag="p"
                  variant="textSM"
                  class="text-foreground font-semibold uppercase"
                >
                  {group.title}
                </Text>
                <ul class="space-y-1">
                  {group.links.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        target={link.target}
                        rel={link.rel}
                        class="text-muted-foreground hover:text-foreground font-medium transition-colors"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </nav>
      </div>
    </div>
  </Wrapper>
  <FooterLogoReveal
    client:load
    className="relative left-1/2 mt-24 flex w-screen -translate-x-1/2 justify-center overflow-hidden leading-none"
  />
  <script is:inline>
    const setupTimes = document.querySelectorAll("[data-setup-time]");
    const setupTime = new Date(Date.now() + 5 * 60 * 1000);
    const formattedSetupTime = new Intl.DateTimeFormat([], {
      hour: "numeric",
      minute: "2-digit",
    })
      .format(setupTime)
      .replace(/\s/g, "")
      .toLowerCase();
    setupTimes.forEach((node) => {
      node.textContent = formattedSetupTime;
    });
  </script>
</footer>
