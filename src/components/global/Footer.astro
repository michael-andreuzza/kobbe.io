---
import Logo from "@/components/assets/Logo.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import Text from "@/components/foundations/elements/Text.astro";
import FooterCtaVisual from "@/components/global/footer-cta-visual";
import { buttonVariants } from "@/components/ui/button";
import { pricingTrialDays } from "@/components/sections/pricing/pricing-tiers";
import { marketingPaths } from "@/lib/marketing-urls";
import { cn } from "@/lib/utils";
import juncosImg from "@/images/assets/backgrounds/juncos.png";

type FooterLink = {
  href: string;
  label: string;
  target?: string;
  rel?: string;
};

type FooterLinkGroup = {
  title: string;
  links: FooterLink[];
};

/** Mirrors `AllFeatures.astro` — keep in sync when feature links change. */
const footerFeatureLinkGroups: FooterLinkGroup[] = [
  {
    title: "Overview",
    links: [
      { href: "/docs/dashboard-stats-kpis", label: "Traffic overview" },
      { href: "/docs/dashboard-overview", label: "Range comparisons" },
      { href: "/docs/realtime-visitors", label: "Realtime visitors" },
    ],
  },
  {
    title: "Breakdowns",
    links: [
      { href: "/docs/dashboard-stats-pages", label: "Pages and paths" },
      {
        href: "/docs/dashboard-stats-sources",
        label: "Sources, channels, and AI traffic",
      },
      {
        href: "/docs/dashboard-stats-locations",
        label: "Locations and devices",
      },
      { href: "/docs/search-console", label: "Search Console insights" },
      { href: "/docs/utm-campaigns", label: "UTM campaigns" },
    ],
  },
  {
    title: "Events",
    links: [
      { href: "/docs/custom-events", label: "Custom events" },
      { href: "/docs/conversions", label: "Conversions" },
      { href: "/docs/funnels", label: "Funnels" },
      { href: "/docs/scroll-tracking", label: "Scroll visibility events" },
    ],
  },
  {
    title: "Tracking",
    links: [
      { href: "/docs/hash-page-paths", label: "Hash routes" },
      { href: "/docs/cross-domain-tracking", label: "Cross-domain tracking" },
      { href: "/docs/exclude-visits", label: "Filter your visits" },
      { href: "/docs/reduce-usage", label: "Usage controls" },
    ],
  },
  {
    title: "Revenue",
    links: [
      { href: "/docs/dashboard-stats-revenue", label: "Revenue dashboard" },
      { href: "/docs/revenue-attribution", label: "Checkout attribution" },
      { href: "/docs/revenue-attribution", label: "Payment integrations" },
    ],
  },
  {
    title: "Privacy",
    links: [
      {
        href: "/docs/privacy-and-cookieless-tracking",
        label: "Private by default",
      },
      { href: "/legal/gdpr-compliance", label: "No raw IP storage" },
      { href: "/docs/script-options", label: "Bot filtering" },
      {
        href: "/docs/privacy-and-cookieless-tracking",
        label: "Privacy signals",
      },
      { href: "/docs/data-export", label: "Data export" },
      { href: "/docs/import-analytics-data", label: "Import analytics data" },
      { href: "/legal/gdpr-compliance", label: "Legal docs and DPA" },
    ],
  },
  {
    title: "Setup",
    links: [
      { href: "/docs/add-the-tracker", label: "Lightweight tracker" },
      { href: "/docs/script-options", label: "Script options" },
      { href: "/docs/first-party-collect", label: "First-party collect" },
      { href: "/docs/installation-guides", label: "Install guides" },
      { href: "/docs/cli", label: "CLI" },
      { href: "/docs/ai-agents", label: "AI agents and MCP" },
      { href: "/docs/dashboard-overview", label: "Site-level settings" },
      {
        href: "/docs/performance-web-vitals",
        label: "Performance and Web Vitals",
      },
    ],
  },
  {
    title: "Sharing",
    links: [
      { href: "/docs/team-access", label: "Team access" },
      { href: "/docs/shared-dashboards", label: "Shared dashboards" },
      { href: "/docs/share-metric-images", label: "Share metric images" },
      { href: "/docs/monthly-reports", label: "Monthly reports" },
      { href: "/docs/traffic-alerts", label: "Traffic alerts" },
    ],
  },
];

const footerLinkGroups: FooterLinkGroup[] = [
  {
    title: "Product",
    links: [
      { href: "/#benefits", label: "All features" },
      { href: "/#pricing", label: "Pricing" },
      { href: "/docs", label: "Documentation" },
      { href: "/llms.txt", label: "llms.txt" },
    ],
  },
  {
    title: "Support",
    links: [
      { href: marketingPaths.support.contact, label: "Contact" },
      { href: "/#faq", label: "FAQ" },
      { href: marketingPaths.support.charges, label: "Charges" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/docs/legal-terms", label: "Terms" },
      { href: "/docs/legal-privacy", label: "Privacy" },
      { href: "/docs/legal-gdpr-compliance", label: "GDPR" },
      { href: "/docs/legal-dpa", label: "DPA" },
    ],
  },
  {
    title: "More",
    links: [
      {
        href: "https://onmy.land",
        label: "More than link in bio",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      {
        href: "http://lexingtonthemes.com/",
        label: "Astro Website templates",
        target: "_blank",
        rel: "noopener noreferrer",
      },
    ],
  },
];
---

<footer class="relative overflow-x-clip pt-20 pb-8">
  <img
    src={juncosImg.src}
    width={juncosImg.width}
    height={juncosImg.height}
    alt=""
    aria-hidden="true"
    decoding="async"
    loading="lazy"
    class="pointer-events-none absolute right-0 bottom-0 z-0 h-auto w-36 select-none sm:w-44 lg:w-56"
  />
  <Wrapper variant="default" class="relative z-10">
    <div
      class="border-border bg-background text-foreground overflow-hidden rounded-2xl border"
    >
      <div class="grid lg:grid-cols-3">
        <div
          class="flex flex-col justify-center p-8 text-balance lg:col-span-2 lg:p-20 lg:text-left"
        >
          <div class="max-w-md">
            <div class="flex flex-col gap-3">
              <Logo
                class="text-foreground h-12 w-fit shrink-0"
                aria-hidden="true"
              />
              <Text
                tag="h2"
                variant="displayMD"
                class="text-foreground font-display mt-12"
              >
                Set up in 5 minutes. <br /> Back to marketing by <span
                  data-setup-time>soon</span
                >.
              </Text>
              <Text
                tag="p"
                variant="displaySubtitle"
                class="text-muted-foreground font-medium text-balance"
              >
                Privacy-first web analytics with traffic and revenue in one
                place.
              </Text>
            </div>

            <a
              href="/#pricing"
              data-kobbe-event="Footer CTA - start free trial"
              class={cn(
                buttonVariants({ variant: "default", size: "sm" }),
                "mt-8 lg:mt-48 w-fit lg:mx-0",
              )}
            >
              Start a {pricingTrialDays}-day trial
            </a>
          </div>
        </div>

        <FooterCtaVisual client:visible />
      </div>
    </div>
    <div class="mt-24 w-full">
      <nav class="grid grid-cols-2 gap-8 text-sm md:grid-cols-4 lg:grid-cols-5">
        <Logo class="text-foreground h-12 w-fit shrink-0" aria-hidden="true" />

        {
          footerLinkGroups.map((group) => (
            <div class="space-y-3">
              <Text
                tag="p"
                variant="textXS"
                class="text-foreground font-semibold uppercase"
              >
                {group.title}
              </Text>
              <ul class="space-y-1">
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target={link.target}
                      rel={link.rel}
                      class="text-muted-foreground hover:text-foreground text-xs font-medium transition-colors"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
      <nav
        class="mt-12 grid grid-cols-2 gap-x-8 gap-y-10 border-t pt-12 text-sm md:grid-cols-4 lg:grid-cols-5"
      >
        {
          footerFeatureLinkGroups.map((group) => (
            <div class="space-y-3">
              <Text
                tag="p"
                variant="textXS"
                class="text-foreground font-semibold uppercase"
              >
                {group.title}
              </Text>
              <ul class="space-y-1">
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target={link.target}
                      rel={link.rel}
                      class="text-muted-foreground hover:text-foreground text-xs font-medium transition-colors"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
      <div
        class="border-border mt-24 flex flex-wrap items-center justify-between gap-2 border-t pt-4 text-xs font-semibold uppercase lg:mt-48"
      >
        <div class="text-muted-foreground flex items-center gap-2">
          <svg
            class="h-6"
            viewBox="0 0 124 155"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <g clip-path="url(#aland-flag-clip)">
              <path
                d="M122.729 15.9559L63.4249 0L0.113977 15.9559C0.113977 31.38 -1.48882 63.8238 7.32662 97.3313C16.1421 130.839 47.1297 146.529 63.4249 154.773C95.4811 138.817 109.426 116.478 117.119 97.3313C124.812 78.1841 123.797 35.1031 122.729 15.9559Z"
                fill="#0454A5"></path>
              <mask
                id="aland-flag-mask"
                style="mask-type:alpha"
                maskUnits="userSpaceOnUse"
                x="0"
                y="0"
                width="124"
                height="155"
              >
                <path
                  d="M122.729 15.9559L63.4249 0L0.113977 15.9559C0.113977 31.38 -1.48882 63.8238 7.32662 97.3313C16.1421 130.839 47.1297 146.529 63.4249 154.773C95.4811 138.817 109.426 116.478 117.119 97.3313C124.812 78.1841 123.797 35.1031 122.729 15.9559Z"
                  fill="white"></path>
              </mask>
              <g mask="url(#aland-flag-mask)">
                <rect
                  x="0.264282"
                  y="77"
                  width="32"
                  height="123"
                  transform="rotate(-90 0.264282 77)"
                  fill="#FECE0A"></rect>
                <rect x="25.2643" width="32" height="155" fill="#FECE0A"></rect>
                <rect x="33" width="16" height="155" fill="#DD1823"></rect>
                <rect
                  y="69"
                  width="16"
                  height="123"
                  transform="rotate(-90 0 69)"
                  fill="#DD1823"></rect>
              </g>
            </g>
            <defs>
              <clipPath id="aland-flag-clip">
                <rect width="123.46" height="154.773" fill="white"></rect>
              </clipPath>
            </defs>
          </svg>
          <span>Made in the Åland Islands</span>
        </div>
        <p class="text-foreground">
          &copy; {new Date().getFullYear()} Kobbe. All rights reserved.
        </p>
      </div>
    </div>
  </Wrapper>
  <script is:inline>
    const setupTimes = document.querySelectorAll("[data-setup-time]");
    const setupTime = new Date(Date.now() + 5 * 60 * 1000);
    const formattedSetupTime = new Intl.DateTimeFormat([], {
      hour: "numeric",
      minute: "2-digit",
    })
      .format(setupTime)
      .replace(/\s/g, "")
      .toLowerCase();
    setupTimes.forEach((node) => {
      node.textContent = formattedSetupTime;
    });
  </script>
</footer>
