22C28.2719 3.57422 27.9223 3.70312 27.6527 3.96094C27.3871 4.21484 27.2289 4.5625 27.1781 5.00391Z"
        fill="#353535"></path>
    </svg>
  </Wrapper>
  <script is:inline>
    const setupTimes = document.querySelectorAll("[data-setup-time]");
    const setupTime = new Date(Date.now() + 5 * 60 * 1000);
    const formattedSetupTime = new Intl.DateTimeFormat([], {
      hour: "numeric",
      minute: "2-digit",
    })
      .format(setupTime)
      .replace(/\s/g, "")
      .toLowerCase();
    setupTimes.forEach((node) => {
      node.textContent = formattedSetupTime;
    });
  </script>
</footer>
