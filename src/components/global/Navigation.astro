---
const navLinks = [
  { href: "/docs", label: "Docs" },
  { href: "/pricing", label: "Pricing" },
  { href: "https://app.kobbe.io", label: "Sign in", external: true },
];
---

<header
  class="border-border/60 bg-background/80 sticky top-0 z-40 border-b backdrop-blur-lg"
>
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
    <a
      href="/"
      aria-label="Homepage"
      class="text-foreground flex items-center gap-2 font-medium tracking-tight"
    >
      Kobbe
    </a>
    <nav class="flex items-center gap-6" role="list">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-muted-foreground hover:text-foreground text-sm transition-colors"
            {...(link.external
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
