---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<aside class={`hidden xl:block ${className}`.trim()}>
  <div class="sticky top-32 space-y-8">
    <nav aria-label="Table of contents">
      <h3 class="text-foreground text-xs font-semibold tracking-wide uppercase">
        On this page
      </h3>
      <ol data-toc-list role="list" class="mt-3 flex flex-col gap-2">
        <li data-toc-empty class="text-muted-foreground text-xs/5">
          No sections on this page.
        </li>
      </ol>
    </nav>
  </div>
</aside>
