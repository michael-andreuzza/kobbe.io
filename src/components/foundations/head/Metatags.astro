---
import SiteSeo from "@/components/foundations/head/SiteSeo.astro";

export interface SEOProps {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  nofollow?: boolean;
  openGraph?: {
    image?: string;
    url?: string;
    type?: string;
    imageAlt?: string;
    imageHeight?: number;
    imageWidth?: number;
  };
  twitter?: {
    image?: string;
  };
  jsonLdExtra?: Record<string, unknown>[];
}

const { seo = {} as SEOProps } = Astro.props;
const {
  title = "Kobbe — Web analytics that respect your visitors",
  description = "Privacy-friendly, cookie-free website analytics. See your traffic, top pages, referrers, locations, and devices in a clean dashboard.",
  canonical,
  noindex = false,
  nofollow = false,
  openGraph = {},
  jsonLdExtra = [],
} = seo;
---

<SiteSeo
  title={title}
  description={description}
  canonical={canonical}
  ogImage={openGraph.image}
  ogImageAlt={openGraph.imageAlt}
  ogImageHeight={openGraph.imageHeight}
  ogImageWidth={openGraph.imageWidth}
  ogType={openGraph.type}
  noindex={noindex}
  nofollow={nofollow}
  jsonLdExtra={jsonLdExtra}
/>
