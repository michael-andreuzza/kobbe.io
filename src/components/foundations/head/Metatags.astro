---
export interface SEOProps {
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  openGraph?: {
    image?: string;
    url?: string;
    type?: string;
  };
  twitter?: {
    image?: string;
    site?: string;
    creator?: string;
    card?: string; // "summary_large_image"
  };
}

const { seo = {} as SEOProps } = Astro.props;
const {
  title,
  description,
  canonical,
  robots = "index, follow",
  openGraph = {},
  twitter = {},
} = seo;

// Ensure og:url always matches canonical unless explicitly overridden
const ogUrl = openGraph.url ?? canonical;
const siteBase = "https://lexingtonthemes.com";
const toAbsoluteUrl = (url?: string) => {
  if (!url) return undefined;
  if (/^https?:\/\//i.test(url)) return url;
  return `${siteBase}${url.startsWith("/") ? "" : "/"}${url}`;
};
const ogImage = toAbsoluteUrl(openGraph.image);
const twitterImage = toAbsoluteUrl(twitter.image);
---

<meta charset="utf-8" />
<meta name="robots" content={robots} />
{title && <title>{title}</title>}
{description && <meta name="description" content={description} />}
{canonical && <link rel="canonical" href={canonical} />}

<!-- Open Graph -->
<meta property="og:type" content={openGraph.type ?? "website"} />
{ogUrl && <meta property="og:url" content={ogUrl} />}
{title && <meta property="og:title" content={title} />}
{description && <meta property="og:description" content={description} />}
{ogImage && <meta property="og:image" content={ogImage} />}

<!-- Twitter -->
<meta name="twitter:card" content={twitter.card ?? "summary_large_image"} />
{twitter.site && <meta name="twitter:site" content={twitter.site} />}
{twitter.creator && <meta name="twitter:creator" content={twitter.creator} />}
{title && <meta name="twitter:title" content={title} />}
{description && <meta name="twitter:description" content={description} />}
{twitterImage && <meta name="twitter:image" content={twitterImage} />}
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="author" content="Michael Andreuzza" />
<meta
  name="keywords"
  content="Astro templates, Astro website templates, Astro Tailwind CSS templates, Premium Astro templates, Free Astro templates, Responsive Astro themes, SEO-friendly Astro templates, Astro Tailwind SaaS templates, Astro Tailwind portfolio templates, Astro blog templates, Astro documentation templates, Astro eCommerce templates, Astro starter themes, Astro UI kits, Fast Astro websites, Web development with Astro and Tailwind CSS"
/>

<meta name="theme-color" content="#ffffff" />
<meta name="msapplication-TileColor" content="#ffffff" />
