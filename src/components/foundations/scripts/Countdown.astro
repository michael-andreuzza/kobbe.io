<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Handle simple text countdowns (e.g. "2d 10h 30m 15s")
    const simpleCountdowns = document.querySelectorAll("[data-countdown-target]");
    
    // 2. Handle split countdowns (days/hours/minutes/seconds in separate elements)
    // Look for containers with data-countdown-split
    const splitCountdowns = document.querySelectorAll("[data-countdown-split]");

    if (simpleCountdowns.length === 0 && splitCountdowns.length === 0) return;

    const updateAllCountdowns = () => {
      const now = Date.now();
      
      // Update simple text countdowns
      simpleCountdowns.forEach((el) => {
        const dateStr = el.getAttribute("data-countdown-date");
        if (!dateStr) return;
        
        const countDownDate = new Date(dateStr).getTime();
        const distance = countDownDate - now;

        if (distance < 0) {
          el.textContent = "";
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysStr = String(days).padStart(2, "0");
        const hoursStr = String(hours).padStart(2, "0");
        const minutesStr = String(minutes).padStart(2, "0");
        const secondsStr = String(seconds).padStart(2, "0");

        el.textContent = `${daysStr}d ${hoursStr}h ${minutesStr}m ${secondsStr}s`;
      });

      // Update split countdowns
      splitCountdowns.forEach((container) => {
        const dateStr = container.getAttribute("data-date");
        if (!dateStr) return;

        const countDownDate = new Date(dateStr).getTime();
        const distance = countDownDate - now;

        if (distance < 0) {
          // Optional: hide container or show expired message
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysEl = container.querySelector("[data-days]");
        const hoursEl = container.querySelector("[data-hours]");
        const minutesEl = container.querySelector("[data-minutes]");
        const secondsEl = container.querySelector("[data-seconds]");

        if (daysEl) daysEl.textContent = String(days).padStart(2, "0");
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, "0");
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, "0");
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, "0");
      });
    };

    updateAllCountdowns();
    setInterval(updateAllCountdowns, 1000);
  });
</script>
