<script is:inline type="module">
  const tocLists = document.querySelectorAll("[data-toc-list]");
  const tocEmptyItems = document.querySelectorAll("[data-toc-empty]");
  const headings = document.querySelectorAll(
    "#markdown-content h2, #markdown-content h3",
  );

  if (tocLists.length === 0) {
    throw new Error("Missing TOC list.");
  }

  const items = Array.from(headings).map((heading) => {
    if (!heading.id) {
      heading.id = heading.textContent
        .toLowerCase()
        .trim()
        .replace(/\s+/g, "-")
        .replace(/[^a-z0-9-]/g, "");
    }

    const headingText = heading.textContent;

    return {
      id: heading.id,
      text: headingText,
      level: heading.tagName.toLowerCase(),
    };
  });

  tocLists.forEach((tocList) => {
    items.forEach((item) => {
      const link = document.createElement("a");
      link.href = `#${item.id}`;
      link.textContent = item.text;
      link.className =
        "flex text-xs/5 text-muted-foreground transition-colors hover:text-foreground";

      const li = document.createElement("li");
      li.className = item.level === "h3" ? "pl-3" : "";
      li.appendChild(link);
      tocList.appendChild(li);
    });
  });

  if (headings.length > 0) {
    tocEmptyItems.forEach((item) => item.remove());
  }
</script>
