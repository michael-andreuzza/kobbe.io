<script>
  function initLogoContextMenu() {
    const logoTrigger = document.getElementById("logo-trigger");
    const contextMenu = document.getElementById("logo-context-menu");
    const copySymbolBtn = document.getElementById("copy-symbol");
    const copyWordmarkBtn = document.getElementById("copy-wordmark");
    const downloadZipBtn = document.getElementById("download-brand-zip");
    const speakBtn = document.getElementById("speak-pronunciation");

    if (!logoTrigger || !contextMenu) return;

    // Speak pronunciation using audio file
    speakBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      const audio = new Audio("/audio/lexington.mp3");
      audio.play().catch(() => {
        // Fallback to speech synthesis if audio fails
        if ("speechSynthesis" in window) {
          speechSynthesis.cancel();
          const utterance = new SpeechSynthesisUtterance("Lexington");
          utterance.lang = "en-US";
          utterance.rate = 0.85;
          speechSynthesis.speak(utterance);
        }
      });
    });

    // Show context menu on right-click
    logoTrigger.oncontextmenu = (e) => {
      e.preventDefault();
      contextMenu.classList.remove("hidden");
      return false;
    };

    // Hide context menu when clicking outside
    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!contextMenu.contains(target) && !logoTrigger.contains(target)) {
        contextMenu.classList.add("hidden");
      }
    });

    // Hide on escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        contextMenu.classList.add("hidden");
      }
    });

    // Copy symbol SVG
    copySymbolBtn?.addEventListener("click", async () => {
      const symbolData = document.getElementById("symbol-svg-data");
      const svg = (symbolData as HTMLElement)?.dataset?.svg || "";
      try {
        await navigator.clipboard.writeText(svg);
        showFeedback(copySymbolBtn, "Copied!");
      } catch {
        showFeedback(copySymbolBtn, "Failed");
      }
    });

    // Copy wordmark SVG
    copyWordmarkBtn?.addEventListener("click", async () => {
      const wordmarkData = document.getElementById("wordmark-svg-data");
      const svg = (wordmarkData as HTMLElement)?.dataset?.svg || "";
      try {
        await navigator.clipboard.writeText(svg);
        showFeedback(copyWordmarkBtn, "Copied!");
      } catch {
        showFeedback(copyWordmarkBtn, "Failed");
      }
    });

    // Download ZIP with both SVGs
    downloadZipBtn?.addEventListener("click", async () => {
      const symbolData = document.getElementById("symbol-svg-data");
      const wordmarkData = document.getElementById("wordmark-svg-data");
      const symbolSvg = (symbolData as HTMLElement)?.dataset?.svg || "";
      const wordmarkSvg = (wordmarkData as HTMLElement)?.dataset?.svg || "";

      try {
        // Create ZIP using JSZip-like approach with native APIs
        const files = [
          { name: "lexington-symbol.svg", content: symbolSvg },
          { name: "lexington-wordmark.svg", content: wordmarkSvg },
        ];

        // Create a simple ZIP file manually
        const zip = await createZip(files);
        const blob = new Blob([zip], { type: "application/zip" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = "lexington-brand-assets.zip";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);

        showFeedback(downloadZipBtn, "Downloaded!");
      } catch {
        showFeedback(downloadZipBtn, "Failed");
      }
    });

    // Simple ZIP creator (no external dependencies)
    async function createZip(
      files: { name: string; content: string }[]
    ): Promise<Uint8Array> {
      const encoder = new TextEncoder();
      const parts: Uint8Array[] = [];
      const centralDirectory: Uint8Array[] = [];
      let offset = 0;

      for (const file of files) {
        const content = encoder.encode(file.content);
        const fileName = encoder.encode(file.name);
        const date = new Date();
        const modTime =
          ((date.getHours() << 11) |
            (date.getMinutes() << 5) |
            (date.getSeconds() >> 1)) &
          0xffff;
        const modDate =
          (((date.getFullYear() - 1980) << 9) |
            ((date.getMonth() + 1) << 5) |
            date.getDate()) &
          0xffff;

        // CRC32
        const crc = crc32(content);

        // Local file header
        const localHeader = new Uint8Array(30 + fileName.length);
        const lhView = new DataView(localHeader.buffer);
        lhView.setUint32(0, 0x04034b50, true); // signature
        lhView.setUint16(4, 20, true); // version needed
        lhView.setUint16(6, 0, true); // flags
        lhView.setUint16(8, 0, true); // compression (none)
        lhView.setUint16(10, modTime, true);
        lhView.setUint16(12, modDate, true);
        lhView.setUint32(14, crc, true);
        lhView.setUint32(18, content.length, true); // compressed size
        lhView.setUint32(22, content.length, true); // uncompressed size
        lhView.setUint16(26, fileName.length, true);
        lhView.setUint16(28, 0, true); // extra field length
        localHeader.set(fileName, 30);

        parts.push(localHeader);
        parts.push(content);

        // Central directory header
        const cdHeader = new Uint8Array(46 + fileName.length);
        const cdView = new DataView(cdHeader.buffer);
        cdView.setUint32(0, 0x02014b50, true); // signature
        cdView.setUint16(4, 20, true); // version made by
        cdView.setUint16(6, 20, true); // version needed
        cdView.setUint16(8, 0, true); // flags
        cdView.setUint16(10, 0, true); // compression
        cdView.setUint16(12, modTime, true);
        cdView.setUint16(14, modDate, true);
        cdView.setUint32(16, crc, true);
        cdView.setUint32(20, content.length, true);
        cdView.setUint32(24, content.length, true);
        cdView.setUint16(28, fileName.length, true);
        cdView.setUint16(30, 0, true); // extra field length
        cdView.setUint16(32, 0, true); // comment length
        cdView.setUint16(34, 0, true); // disk number
        cdView.setUint16(36, 0, true); // internal attributes
        cdView.setUint32(38, 0, true); // external attributes
        cdView.setUint32(42, offset, true); // offset
        cdHeader.set(fileName, 46);

        centralDirectory.push(cdHeader);
        offset += localHeader.length + content.length;
      }

      const cdOffset = offset;
      let cdSize = 0;
      for (const cd of centralDirectory) {
        parts.push(cd);
        cdSize += cd.length;
      }

      // End of central directory
      const eocd = new Uint8Array(22);
      const eocdView = new DataView(eocd.buffer);
      eocdView.setUint32(0, 0x06054b50, true);
      eocdView.setUint16(4, 0, true);
      eocdView.setUint16(6, 0, true);
      eocdView.setUint16(8, files.length, true);
      eocdView.setUint16(10, files.length, true);
      eocdView.setUint32(12, cdSize, true);
      eocdView.setUint32(16, cdOffset, true);
      eocdView.setUint16(20, 0, true);
      parts.push(eocd);

      // Combine all parts
      const totalLength = parts.reduce((sum, p) => sum + p.length, 0);
      const result = new Uint8Array(totalLength);
      let pos = 0;
      for (const part of parts) {
        result.set(part, pos);
        pos += part.length;
      }
      return result;
    }

    function crc32(data: Uint8Array): number {
      let crc = 0xffffffff;
      const table = getCrc32Table();
      for (let i = 0; i < data.length; i++) {
        crc = (crc >>> 8) ^ table[(crc ^ data[i]) & 0xff];
      }
      return (crc ^ 0xffffffff) >>> 0;
    }

    function getCrc32Table(): number[] {
      const table: number[] = [];
      for (let i = 0; i < 256; i++) {
        let c = i;
        for (let j = 0; j < 8; j++) {
          c = c & 1 ? 0xedb88320 ^ (c >>> 1) : c >>> 1;
        }
        table.push(c >>> 0);
      }
      return table;
    }

    function showFeedback(btn: Element, msg: string) {
      const span = btn.querySelector("span:last-child");
      if (!span) return;
      const original = span.textContent || "";
      span.textContent = msg;
      setTimeout(() => {
        span.textContent = original;
        contextMenu.classList.add("hidden");
      }, 1000);
    }
  }

  // Run on initial load
  initLogoContextMenu();

  // Also run after View Transitions (Astro)
  document.addEventListener("astro:page-load", initLogoContextMenu);
</script>
