---
import Button from "./Button.astro";
interface Props {
  targetId: string;
  batchSize?: number;
  label?: string;
  class?: string;
  [key: string]: any;
}
const {
  targetId,
  batchSize = 6,
  label = "Load more",
  class: className,
  ...rest
} = Astro.props as Props;
---

<Button
  size="xs"
  variant="default"
  type="button"
  id={`load-more-${targetId}`}
  class={className ?? ""}
  data-target={targetId}
  data-batch-size={batchSize}
  {...rest}
>
  {label}
</Button>
<script is:inline>
  (function () {
    function init() {
      var buttons = document.querySelectorAll(
        "[id^='load-more-'][data-target]"
      );
      buttons.forEach(function (btn) {
        if (btn._loadMoreBound) return;
        btn._loadMoreBound = true;
        var targetId = btn.dataset.target;
        if (!targetId) return;
        var container = document.getElementById(targetId);
        if (!container) return;
        var batchSize = parseInt(btn.dataset.batchSize, 10) || 6;
        var items = container.querySelectorAll("[data-load-more-item]");
        var currentIndex = 0;
        // Hide all items initially
        items.forEach(function (item) {
          item.classList.add("hidden");
        });
        // Show first batch
        function showNextBatch() {
          var end = Math.min(currentIndex + batchSize, items.length);
          for (var i = currentIndex; i < end; i++) {
            items[i].classList.remove("hidden");
          }
          currentIndex = end;
          // Hide button if no more items
          if (currentIndex >= items.length) {
            btn.style.display = "none";
          }
        }
        // Show initial batch
        showNextBatch();
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          showNextBatch();
        });
      });
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
