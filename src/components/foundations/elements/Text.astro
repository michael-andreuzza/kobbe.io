---
// Text.astro
export interface Props {
  tag?:
    | "p"
    | "a"
    | "span"
    | "small"
    | "div"
    | "strong"
    | "em"
    | "blockquote"
    | "dd"
    | "dt"
    | "summary"
    | "label"
    | "h1"
    | "h2"
    | "h3"
    | "h4"
    | "h5"
    | "h6";
  variant?: string; // Consider renaming it 'textVariant' for clarity
  level?: number; // Added level prop for heading levels
  class?: string;
  for?: string; // Add 'for' attribute for label tags
  id?: string; // Add 'id' attribute for label tags
  href?: string; // Add 'href' attribute for anchor tags
  title?: string; // Add 'title' attribute for anchor tags
  target?: string; // Add 'target' attribute for anchor tags
  rel?: string; // Add 'rel' attribute for anchor tags
}
// Define the text styles with all specified variants
const textStyles: { [key: string]: string } = {
  // Utility
  displayTitle: "text-3xl 2xl:text-6xl",
  displaySubTitle: "text-base  md:text-base 2xl:text-2xl",
  // Base
  display6XL:
    "text-4xl  sm:text-7xl md:text-9xl lg:text-[12rem] 2xl:text-[15rem]",
  display5XL:
    "text-4xl  sm:text-7xl md:text-8xl lg:text-[10rem] 2xl:text-[14rem]",
  display4XL: "text-4xl  sm:text-7xl md:text-8xl lg:text-9xl 2xl:text-[12rem]",
  display3XL: "text-5xl  sm:text-6xl md:text-7xl lg:text-8xl 2xl:text-[10rem]",
  display2XL: "text-5xl  sm:text-5xl md:text-6xl lg:text-7xl 2xl:text-9xl",
  displayXL: "text-4xl  sm:text-4xl md:text-5xl lg:text-6xl 2xl:text-8xl",
  displayLG: "text-3xl  sm:text-3xl md:text-4xl lg:text-5xl 2xl:text-7xl",
  displayMD: "text-2xl  sm:text-2xl md:text-3xl lg:text-4xl 2xl:text-6xl",
  displaySM: "text-lg  sm:text-xl md:text-2xl lg:text-3xl 2xl:text-5xl",
  displayXS: "text-base  sm:text-lg md:text-xl lg:text-2xl 2xl:text-4xl",
  textXL: "text-lg sm:text-xl md:text-2xl 2xl:text-3xl",
  textLG: "text-base sm:text-lg md:text-xl 2xl:text-2xl",
  textBase: "text-base 2xl:text-lg",
  textSM: "text-sm 2xl:text-base",
  textXS: "text-xs 2xl:text-sm",
  textXXS: "text-[0.65rem] md:text-xs 2xl:text-sm", // probably leave as-is
};
const {
  tag: Tag = "p", // default to paragraph
  variant = "textBase", // default to textMD variant
  level = 2, // default to level 2 for headings
  class: className = "",
  for: htmlFor, // Capture 'for' attribute
  ...rest
} = Astro.props;
// Get the base classes for the variant
const baseClasses = textStyles[variant] || textStyles.textMD; // Default to textMD if not found
// Combine base classes with any additional custom classes
const combinedClasses = `${baseClasses} ${className}`.trim();
---

<Tag class={combinedClasses} {...rest}>
  <slot name="left-icon" />
  <slot />
  <slot name="right-icon" />
</Tag>
