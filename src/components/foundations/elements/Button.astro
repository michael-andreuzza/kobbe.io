---
// ButtonLink.astro
// Polymorphic button/link with icon-only + size/gap variants
interface Props {
  href?: string;
  isLink?: boolean; // force <a> even without href (rare)
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  // Visuals
  variant?:
    | "default"
    | "accent"
    | "muted"
    | "alternative"
    | "mutedDark"
    | "link"
    | "none";
  size?:
    | "extraMini"
    | "mini"
    | "xs"
    | "sm"
    | "base"
    | "md"
    | "lg"
    | "xl"
    | "xxl"
    | "huge";
  gap?: "xs" | "sm" | "base" | "md" | "lg";
  iconOnly?: boolean; // square icon-only button
  onlyIconSize?: never; // kept for API parity; not used
  noSize?: boolean; // disable size classes
  // Misc
  target?: "_self" | "_blank" | "_parent" | "_top";
  rel?: string;
  "aria-label"?: string;
  class?: string;
  [key: string]: any;
}
const {
  href,
  isLink,
  type = "button",
  disabled = false,
  variant = "default",
  size = "base",
  gap,
  iconOnly = false,
  noSize = false,
  target,
  rel,
  "aria-label": ariaLabel,
  class: className,
  ...rest
} = Astro.props as Props;
// Variant classes (keep your originals)
const defaultClass = [
  "bg-dark-surface",
  "text-foreground-on-dark",
  "focus:ring-foreground",
  "hover:bg-dark-surface/90",
];
const accentClass = [
  "text-foreground-on-dark  ",
  "bg-accent",
  "hover:bg-accent-dark",
  "focus:ring-accent-dark",
];
const mutedClass = [
  "text-foreground",
  "bg-muted-surface",
  "hover:text-muted-foreground",
  "focus:ring-muted-foreground",
];
const mutedDarkClass = [
  "text-foreground-on-dark",
  "bg-background/15",
  "hover:bg-dark-surface",
  "focus:outline-accent",
];
const alternativeClass = [
  "text-foreground",
  "bg-background",
  "hover:bg-muted-surface",
  "focus:outline-accent",
];
const variantClassMap: Record<string, string[]> = {
  default: defaultClass,
  accent: accentClass,
  muted: mutedClass,
  alternative: alternativeClass,
  mutedDark: mutedDarkClass,
  link: [], // style externally if needed
  none: [], // naked
};
// Size classes
const sizeClasses = !noSize
  ? iconOnly
    ? (
        {
          extraMini: ["size-7", "p-1", "text-[0.69rem]"],
          mini: ["size-8", "p-1", "text-xs"],
          xs: ["size-9", "p-2", "text-xs"],
          sm: ["size-10", "p-2", "text-sm"],
          base: ["size-11", "p-3", "text-base"],
          md: ["size-12", "p-3", "text-lg"],
          lg: ["size-13", "p-3", "text-lg"],
          xl: ["size-14", "p-3", "text-lg"],
          xxl: ["size-15", "p-3", "text-lg"],
        } as Record<string, string[]>
      )[size] || []
    : (
        {
          extraMini: ["h-7", "px-3", "py-1", "text-[0.69rem]"],
          mini: ["h-8", "px-3", "py-1", "text-xs"],
          xs: ["h-9", "px-3.5", "py-2", "text-xs"],
          sm: ["h-10", "px-3.5", "py-2", "text-sm"],
          base: ["h-11", "px-4", "py-3", "text-base"],
          md: ["h-12", "px-4", "py-3", "text-lg"],
          lg: ["h-13", "px-4", "py-3", "text-lg"],
          xl: ["h-14.5", "px-6", "py-3", "text-lg"],
          huge: ["h-15", "px-6", "py-4", "text-lg"],
        } as Record<string, string[]>
      )[size] || []
  : [];
// Gap classes
const gapClasses = !iconOnly
  ? (
      {
        xs: ["gap-2"],
        sm: ["gap-4"],
        base: ["gap-8"],
        md: ["gap-10"],
        lg: ["gap-12"],
      } as Record<string, string[]>
    )[gap ?? ""] || []
  : [];
const additionalClasses = className ? className.split(" ") : [];
// Shared base classes
const baseClass = [
  "flex",
  "items-center",
  "text-center",
  "font-medium ",
  "rounded",
  "transition",
  "duration-300",
  "focus:ring-2 focus:ring-inset",
  "focus:outline-none ",
  "select-none",
];
const elementIsLink =
  (isLink ?? Boolean(href)) && variant !== "link" ? true : Boolean(href);
const computedRel =
  target === "_blank" ? (rel ? rel : "noopener noreferrer") : rel;
const disabledClasses = disabled
  ? ["opacity-60", "pointer-events-none", "cursor-not-allowed"]
  : [];
---

{
  elementIsLink ? (
    // <a>
    <a
      href={href}
      target={target}
      rel={computedRel}
      aria-disabled={disabled ? "true" : undefined}
      tabindex={disabled ? -1 : undefined}
      aria-label={iconOnly ? ariaLabel : ariaLabel}
      class:list={[
        ...baseClass,
        ...(variantClassMap[variant] || []),
        ...sizeClasses,
        ...gapClasses,
        ...disabledClasses,
        ...additionalClasses,
      ]}
      {...rest}
    >
      {iconOnly ? (
        <slot name="icon" />
      ) : (
        <>
          <slot name="left-icon" />
          <slot />
          <slot name="right-icon" />
        </>
      )}
    </a>
  ) : (
    // <button>
    <button
      type={type}
      disabled={disabled}
      aria-label={iconOnly ? ariaLabel : ariaLabel}
      class:list={[
        ...baseClass,
        ...(variantClassMap[variant] || []),
        ...sizeClasses,
        ...gapClasses,
        ...disabledClasses,
        ...additionalClasses,
      ]}
      {...rest}
    >
      {iconOnly ? (
        <slot name="icon" />
      ) : (
        <>
          <slot name="left-icon" />
          <slot />
          <slot name="right-icon" />
        </>
      )}
    </button>
  )
}
