---
// src/components/TabButton.astro
export interface Props {
  tab: string;
  class?: string;
  selected?: boolean;
  id?: string;
  controls?: string;
}

const {
  tab,
  class: className = "",
  selected = false,
  id = `tab-${tab}`,
  controls = `panel-${tab}`,
} = Astro.props;
---

<button
  role="tab"
  type="button"
  id={id}
  aria-selected={selected}
  aria-controls={controls}
  tabindex={selected ? "0" : "-1"}
  data-tab-button
  data-tab={tab}
  class={`flex items-center gap-2 px-4 py-3 text-sm font-medium cursor-pointer border-b-2 border-none transition-all duration-200 text-muted-foreground hover:text-foreground not-prose ${className}`}
>
  <slot name="left-icon" />
  <slot />
  <slot name="right-icon" />
</button>
