---
import Text from "@/components/foundations/elements/Text.astro";
import { cn } from "@/lib/utils";

interface Props {
  title: string;
  description: string;
  tag?: "h1" | "h2" | "h3";
  id?: string;
  headingColor?: string;
}

const { title, description, tag = "h2", id, headingColor } = Astro.props;
---

<div class="text-pretty lg:mx-auto lg:max-w-200 lg:text-center lg:text-balance">
  <Text
    id={id}
    tag={tag}
    variant="displaySM"
    class={cn("text-foreground font-display ", headingColor)}
  >
    {title}
  </Text>
  <Text
    tag="p"
    variant="textBase"
    class="text-muted-foreground mt-1 font-normal"
  >
    {description}
  </Text>
</div>
