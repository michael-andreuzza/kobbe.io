---
import Text from "@/components/foundations/elements/Text.astro";
import TrackingModeBadge from "@/components/foundations/elements/TrackingModeBadge.astro";
import type { TrackingMode } from "@/components/landing/tracking-mode-badge";
import { cn } from "@/lib/utils";

interface Props {
  title: string;
  description: string;
  tag?: "h1" | "h2" | "h3";
  id?: string;
  headingColor?: string;
  mode?: TrackingMode;
}

const { title, description, tag = "h2", id, headingColor, mode } = Astro.props;
---

<div class="text-balance lg:mx-auto lg:max-w-200 lg:text-center">
  {
    mode ? (
      <div class="mb-3 flex justify-center lg:justify-center">
        <TrackingModeBadge mode={mode} />
      </div>
    ) : null
  }
  <Text
    id={id}
    tag={tag}
    variant="displaySM"
    class={cn("text-foreground font-display", headingColor)}
  >
    {title}
  </Text>
  <Text
    tag="p"
    variant="textBase"
    class="text-muted-foreground mt-1 font-normal"
  >
    {description}
  </Text>
</div>
