---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import PerformanceDashboardPreview from "@/components/landing/dashboard/performance-dashboard-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";

type PerformancePreview = {
  metrics: {
    name: "LCP" | "INP" | "CLS" | "TTFB" | "FCP";
    value: string;
    rating: "Good" | "Watch" | "Poor";
    sampleCount: number;
  }[];
  environments: { name: string; count: number }[];
};

const performancePreview: PerformancePreview = {
  metrics: [
    { name: "LCP", value: "1.8s", rating: "Good", sampleCount: 1284 },
    { name: "INP", value: "92ms", rating: "Good", sampleCount: 1172 },
    { name: "CLS", value: "0.03", rating: "Good", sampleCount: 1218 },
    { name: "TTFB", value: "420ms", rating: "Watch", sampleCount: 984 },
    { name: "FCP", value: "1.1s", rating: "Good", sampleCount: 1246 },
  ],
  environments: [
    { name: "Chrome desktop", count: 624 },
    { name: "Safari mobile", count: 318 },
    { name: "Firefox desktop", count: 144 },
    { name: "Edge desktop", count: 96 },
  ],
};
---

<section>
  <Wrapper class="py-20">
    <SectionIntro

      title="Keep performance beside your traffic."
      description="Track Core Web Vitals with the same dashboard language: percentile trends, slow pages, and environment breakdowns."
    />

    <div class="group mt-8">
      <AnimatedPanelReveal
        client:load
        trigger="scroll"
        mask={false}
        end="bottom 42%"
        className="transition-transform duration-300 ease-out group-hover:-translate-y-0.5 motion-reduce:transform-none motion-reduce:transition-none"
      >
        <PerformanceDashboardPreview
          client:load
          webVitals={performancePreview}
        />
      </AnimatedPanelReveal>
    </div>
  </Wrapper>
</section>
