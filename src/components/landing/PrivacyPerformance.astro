---
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
---

<section class="border-border/60 border-t">
  <Wrapper class="py-20 lg:py-24">
    
      <Text
        tag="h2"
        variant="displaySM"
        class="text-foreground  font-semibold tracking-tight"
      >
        Analytics without the trade-offs.
      </Text>
      <Text tag="p" variant="textBase" class="text-muted-foreground mt-4">
        No cookies, no persistent visitor profiles, and no raw IP storage. Kobbe
        gives you useful traffic insights while keeping your visitors' privacy
        intact.
      </Text>
    </div>

    <dl
      class="mt-12 grid gap-8 sm:grid-cols-2 lg:mt-16 lg:grid-cols-3 lg:gap-x-12 lg:gap-y-10"
    >
      <div>
        <dt class="text-foreground text-sm font-medium">Cookie-free</dt>
        <dd class="text-muted-foreground mt-2 text-sm/6">
          The default tracker uses no cookies, localStorage, or persistent
          browser identifiers.
        </dd>
      </div>
      <div>
        <dt class="text-foreground text-sm font-medium">Lightweight tracker</dt>
        <dd class="text-muted-foreground mt-2 text-sm/6">
          The default tracker is about 2 KB gzip, loads async, and is designed
          to stay out of the critical rendering path.
        </dd>
      </div>
      <div>
        <dt class="text-foreground text-sm font-medium">
          Privacy-aware attribution
        </dt>
        <dd class="text-muted-foreground mt-2 text-sm/6">
          Optional revenue attribution uses session-scoped, pseudonymous keys.
          You stay in control of when to enable it and how to disclose it.
        </dd>
      </div>
    </dl>
  </Wrapper>
</section>
