---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import RevenueInsightsPreview from "@/components/landing/dashboard/revenue-insights-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";
import { Image } from "astro:assets";
import creemLogo from "@/images/brands/creem.svg";
import paddleLogo from "@/images/brands/paddle.svg";
import polarLogo from "@/images/brands/polar.svg";
import stripeLogo from "@/images/brands/stripe.svg";

const revenueProviders = [
  { name: "Stripe", logo: stripeLogo },
  { name: "Polar", logo: polarLogo },
  { name: "Paddle", logo: paddleLogo },
  { name: "Creem", logo: creemLogo },
];

const revenueInsightsPoints = [
  {
    title: "Connect a source",
    description: "Connect Stripe, Polar, Paddle, or Creem payment webhooks.",
  },
  {
    title: "Keep attribution scoped",
    description:
      "Pass tab-scoped attribution through payment metadata instead of profiling visitors.",
  },
  {
    title: "Read it in context",
    description: "Revenue shows up beside traffic KPIs, pages, and sources.",
  },
];
---

<section class="pt-8">
  <Wrapper class="py-20">
    <div class="mx-auto max-w-4xl">
      <div class="max-w-lg lg:mx-auto lg:text-center">
        <SectionIntro
          mode="extended"
          title="Attribute revenue without turning Kobbe into a CRM."
          description="Pass attribution through checkout and see revenue beside the same pages, sources, and campaigns you already track."
        />
        <div
          class="text-muted-foreground mt-8 flex w-fit flex-wrap items-center gap-x-4 gap-y-2 text-xs font-medium lg:mx-auto"
          aria-label="Supported revenue providers"
        >
          <span class="sr-only">Works with:</span>
          {
            revenueProviders.map((provider) => (
              <span>
                <Image
                  src={provider.logo}
                  alt={`${provider.name} logo`}
                  class="size-6 rounded object-contain"
                  loading="lazy"
                />
                <span class="sr-only">{provider.name}</span>
              </span>
            ))
          }
        </div>
      </div>
    </div>
    <div class="relative mt-8">
      <AnimatedPanelReveal client:load trigger="scroll" mask={false}>
        <RevenueInsightsPreview client:load />
      </AnimatedPanelReveal>
    </div>

    <div class="mt-8 grid gap-4 text-balance sm:grid-cols-3 lg:text-center">
      {
        revenueInsightsPoints.map((point) => (
          <div data-kobbe-stagger>
            <h3 class="text-foreground text-base font-medium">{point.title}</h3>
            <p class="text-muted-foreground mt-1 text-sm font-medium">
              {point.description}
            </p>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
