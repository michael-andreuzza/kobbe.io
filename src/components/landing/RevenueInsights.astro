---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import RevenueInsightsPreview from "@/components/landing/dashboard/revenue-insights-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";
import { Image } from "astro:assets";
import creemLogo from "@/images/brands/creem.svg";
import paddleLogo from "@/images/brands/paddle.svg";
import polarLogo from "@/images/brands/polar.svg";
import stripeLogo from "@/images/brands/stripe.svg";

const revenueProviders = [
  { name: "Stripe", logo: stripeLogo },
  { name: "Polar", logo: polarLogo },
  { name: "Paddle", logo: paddleLogo },
  { name: "Creem", logo: creemLogo },
];
---

<section>
  <Wrapper class="py-20">
    <div class="max-w-lg">
      <SectionIntro
        title="Attribute revenue without turning Kobbe into a CRM."
        description="Add a payment source, pass Kobbe's session attribution through checkout, and revenue appears beside the same pages, sources, and campaigns you already use to understand traffic."
      />
      <div
        class="text-muted-foreground mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-medium"
        aria-label="Supported revenue providers"
      >
        <span class="sr-only">Works with:</span>
        {
          revenueProviders.map((provider) => (
            <span>
              <Image
                src={provider.logo}
                alt={`${provider.name} logo`}
                class="size-6 rounded object-contain grayscale transition-all duration-300 hover:grayscale-0"
                loading="lazy"
              />
              <span class="sr-only">{provider.name}</span>
            </span>
          ))
        }
      </div>
    </div>

    <div class="group mt-8">
      <AnimatedPanelReveal
        client:load
        trigger="scroll"
        className="transition-transform duration-300 ease-out group-hover:-translate-y-0.5 motion-reduce:transform-none motion-reduce:transition-none"
      >
        <RevenueInsightsPreview client:load />
      </AnimatedPanelReveal>
    </div>

    <div class="mt-8 grid gap-4 text-balance sm:grid-cols-3">
      <div data-kobbe-stagger>
        <h3 class="text-foreground text-lg font-medium">Connect a source</h3>
        <p class="text-muted-foreground mt-3 text-base font-medium">
          Use Stripe, Polar, Paddle, or Creem webhooks from site settings.
        </p>
      </div>
      <div data-kobbe-stagger>
        <h3 class="text-foreground text-lg font-medium">
          Keep attribution scoped
        </h3>
        <p class="text-muted-foreground mt-3 text-base font-medium">
          Pass Kobbe's session attribution through checkout instead of profiling
          visitors.
        </p>
      </div>
      <div data-kobbe-stagger>
        <h3 class="text-foreground text-lg font-medium">Read it in context</h3>
        <p class="text-muted-foreground mt-3 text-base font-medium">
          Revenue shows up beside traffic KPIs, pages, and sources.
        </p>
      </div>
    </div>
  </Wrapper>
</section>
