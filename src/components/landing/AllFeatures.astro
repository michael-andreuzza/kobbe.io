---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import FeatureTabs from "@/components/features/feature-tabs";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import SectionIntro from "@/components/landing/SectionIntro.astro";

const featureGroups = [
  {
    category: "Analytics",
    features: [
      {
        title: "Traffic overview",
        description:
          "Visitors, visits, views, bounce rate, session time, and trend changes in one dashboard.",
        href: "/docs/dashboard-stats-kpis",
      },
      {
        title: "Range comparisons",
        description:
          "Compare KPIs and chart trends against previous periods, calendar windows, or custom comparison ranges.",
        href: "/docs/dashboard-overview",
      },
      {
        title: "Pages and paths",
        description:
          "Top pages, entry pages, exit pages, and page-level drilldowns.",
        href: "/docs/dashboard-stats-pages",
      },
      {
        title: "Sources, channels, and AI traffic",
        description:
          "Referrers, campaign channels, hostnames, and AI tools grouped into readable source cards.",
        href: "/docs/dashboard-stats-sources",
      },
      {
        title: "UTM campaigns",
        description:
          "Opt-in campaign reports for UTM traffic and conversions without storing full query strings.",
        href: "/docs/utm-campaigns",
      },
      {
        title: "Realtime visitors",
        description:
          "See current activity, recent events, and what is happening on the site right now.",
        href: "/docs/realtime-visitors",
      },
      {
        title: "Locations and devices",
        description:
          "Countries, regions, cities, browsers, operating systems, and device categories.",
        href: "/docs/dashboard-stats-locations",
      },
      {
        title: "Search Console insights",
        description:
          "Bring organic search queries, clicks, impressions, and ranking data into Kobbe.",
        href: "/docs/search-console",
      },
      {
        title: "Custom events",
        description:
          "Track clicks, signups, downloads, purchases, form completions, and JavaScript goals.",
        href: "/docs/custom-events",
      },
      {
        title: "Conversions",
        description:
          "Auto-track contact clicks, messaging links, outbound links, and form submits with dashboard filters.",
        href: "/docs/conversions",
      },
      {
        title: "Funnels",
        description:
          "Build ordered flows from pageviews and custom events to see where visitors drop off.",
        href: "/docs/funnels",
      },
      {
        title: "Hash routes",
        description:
          "Track SPAs that use URL fragments as routes without storing query strings by default.",
        href: "/docs/hash-page-paths",
      },
      {
        title: "Filter your visits",
        description:
          "Drop internal, staging, path, country, hostname, IP, or browser-level noise before it counts.",
        href: "/docs/exclude-visits",
      },
      {
        title: "Usage controls",
        description:
          "Keep event volume useful with bot filtering, exclusions, and focused optional tracking.",
        href: "/docs/reduce-usage",
      },
      {
        title: "Scroll visibility events",
        description:
          "Measure when visitors reach important sections such as pricing, testimonials, or docs.",
        href: "/docs/scroll-tracking",
        mode: "extended",
      },
      {
        title: "Cross-domain tracking",
        description:
          "Link journeys across root domains with explicit hostname allowlists when you use the full tracker.",
        href: "/docs/cross-domain-tracking",
        mode: "extended",
      },
    ],
  },
  {
    category: "Revenue",
    features: [
      {
        title: "Revenue dashboard",
        description:
          "Attributed revenue, paid orders, conversion context, and revenue rows beside analytics cards.",
        href: "/docs/dashboard-stats-revenue",
        mode: "extended",
      },
      {
        title: "Checkout attribution",
        description:
          "Enable tab-scoped attribution on checkout pages without long-lived visitor profiles or analytics cookies.",
        href: "/docs/revenue-attribution",
        mode: "extended",
      },
      {
        title: "Stripe",
        description:
          "Attribute Stripe checkout and payment events to privacy-friendly analytics sessions.",
        href: "/docs/revenue-attribution-stripe",
        mode: "extended",
      },
      {
        title: "Polar",
        description:
          "Send Kobbe attribution through Polar checkout and reconcile revenue back into reports.",
        href: "/docs/revenue-attribution-polar",
        mode: "extended",
      },
      {
        title: "Paddle",
        description:
          "Connect Paddle revenue events so sales can appear next to pages and sources.",
        href: "/docs/revenue-attribution-paddle",
        mode: "extended",
      },
      {
        title: "Creem",
        description:
          "Use Creem checkout metadata and webhooks with Kobbe revenue attribution.",
        href: "/docs/revenue-attribution-creem",
        mode: "extended",
      },
    ],
  },
  {
    category: "Privacy",
    features: [
      {
        title: "Cookieless by default",
        description:
          "No analytics cookies and no persistent browser-side visitor identifiers for normal tracking.",
        href: "/docs/privacy-and-cookieless-tracking",
      },
      {
        title: "No raw IP storage",
        description:
          "Visitor IPs are minimized at collection time and are not stored raw in the app database.",
        href: "/docs/legal-gdpr-compliance",
      },
      {
        title: "Bot filtering",
        description:
          "Common crawlers, spam, and suspicious automated traffic are filtered before reporting.",
        href: "/docs/script-options",
      },
      {
        title: "Privacy signals",
        description:
          "Global Privacy Control and Do Not Track stop the tracker before any analytics request is sent.",
        href: "/docs/privacy-and-cookieless-tracking",
      },
      {
        title: "Data export",
        description:
          "Export analytics data when you need to archive, report, or analyze it elsewhere.",
        href: "/docs/data-export",
      },
      {
        title: "Legal docs and DPA",
        description:
          "Privacy, GDPR information, terms, and a hosted-service DPA are available in docs.",
        href: "/docs/legal-gdpr-compliance",
      },
    ],
  },
  {
    category: "Setup & sharing",
    features: [
      {
        title: "Lightweight tracker",
        description:
          "Use the small default tracker for pageviews and custom events, or full tracker for advanced features.",
        href: "/docs/add-the-tracker",
      },
      {
        title: "Script options",
        description:
          "Configure custom endpoints, hash routes, debug logging, full-tracker features, and more.",
        href: "/docs/script-options",
      },
      {
        title: "First-party collect",
        description:
          "Serve the tracker and collect endpoint from a Kobbe subdomain or your own CNAME for stricter first-party delivery.",
        href: "/docs/first-party-collect",
      },
      {
        title: "Install guides",
        description:
          "Step-by-step setup for Astro, Next.js, React Router, WordPress, Shopify, Webflow, and more.",
        href: "/docs/installation-guides",
      },
      {
        title: "CLI",
        description:
          "Inspect sites, traffic, revenue, setup health, and site settings from the terminal.",
        href: "/docs/cli",
      },
      {
        title: "AI agents and MCP",
        description:
          "Use the same CLI package in MCP mode so AI tools can inspect Kobbe context.",
        href: "/docs/ai-agents",
      },
      {
        title: "Team access",
        description:
          "Invite teammates to view project dashboards with scoped access.",
        href: "/docs/team-access",
      },
      {
        title: "Shared dashboards",
        description:
          "Create public, read-only dashboard links for clients, teams, or stakeholders.",
        href: "/docs/shared-dashboards",
      },
      {
        title: "Monthly reports",
        description:
          "Send opt-in month-in-review emails with traffic, top pages, sources, and revenue context.",
        href: "/docs/monthly-reports",
      },
      {
        title: "Traffic alerts",
        description:
          "Get notified when traffic spikes or drops sharply against a site's recent baseline.",
        href: "/docs/traffic-alerts",
      },
      {
        title: "Site-level settings",
        description:
          "Keep setup, tokens, conversions, visit filters, integrations, and reporting scoped per site.",
        href: "/docs/dashboard-overview",
      },
      {
        title: "Performance and Web Vitals",
        description:
          "Collect real-user LCP, INP, CLS, FCP, and TTFB when performance tracking is enabled.",
        href: "/docs/performance-web-vitals",
        mode: "extended",
      },
    ],
  },
] as const;
---

<section id="benefits" class="pt-8">
  <Wrapper variant="default" class="py-20">
    <div class="mx-auto max-w-4xl">
      <div class="mx-auto max-w-3xl lg:text-center">
        <SectionIntro
          title="Everything you need to understand your website."
          description="Default tracking stays cookieless. Extended features are opt-in when you need them."
        />
      </div>
      <div class="mt-8">
        <AnimatedPanelReveal client:load trigger="view">
          <FeatureTabs client:load groups={featureGroups} />
        </AnimatedPanelReveal>
      </div>
    </div>
  </Wrapper>
</section>
