---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import DashboardCapabilityGrid from "@/components/landing/dashboard/dashboard-capability-grid";
import SectionIntro from "@/components/landing/SectionIntro.astro";
---
<section class="pt-8">
  <Wrapper class="py-20">
    <div class="max-w-4xl">
      <SectionIntro
        title="Every view you open should answer a real question."
        description="Traffic and revenue, referrers, conversions, search keywords, custom events, realtime visitors, broken links, and chart annotations — useful dashboard views, ready without a heavy setup."
      />
    </div>
    <div class="mt-12">
      <DashboardCapabilityGrid client:load />
    </div>
  </Wrapper>
</section>
