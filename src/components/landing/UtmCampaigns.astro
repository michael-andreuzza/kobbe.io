---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import CampaignsDashboardPreview from "@/components/landing/dashboard/campaigns-dashboard-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";

const campaignsPreview = {
  summary: {
    campaigns: 5,
    visitors: 80,
    views: 282,
    conversions: 44,
  },
  rows: [
    {
      name: "founder-post",
      source: "x",
      medium: "social",
      visitors: 42,
      views: 76,
      conversions: 8,
    },
    {
      name: "privacy-analytics",
      source: "google",
      medium: "organic",
      visitors: 37,
      views: 59,
      conversions: 10,
    },
    {
      name: "launch-week",
      source: "producthunt",
      medium: "referral",
      visitors: 35,
      views: 55,
      conversions: 7,
    },
    {
      name: "agency-bundle",
      source: "newsletter",
      medium: "email",
      visitors: 33,
      views: 49,
      conversions: 14,
    },
    {
      name: "launch-day",
      source: "x",
      medium: "social",
      visitors: 34,
      views: 43,
      conversions: 5,
    },
  ],
};
---

<section class="pt-8">
  <Wrapper class="py-20">
    <div class="max-w-4xl">
      <SectionIntro
        title="Trace every UTM campaign back to real actions."
        description="See campaign visitors, views, sources, and mediums in the same dashboard language as the rest of your traffic reports."
      />
    </div>
    <div class="relative mt-8">
      <AnimatedPanelReveal client:load trigger="scroll" mask={false}>
        <CampaignsDashboardPreview client:load campaigns={campaignsPreview} />
      </AnimatedPanelReveal>
    </div>
  </Wrapper>
</section>
