---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import CampaignsDashboardPreview from "@/components/landing/dashboard/campaigns-dashboard-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";
import { Image } from "astro:assets";
import paintOne from "@/images/assets/background.svg";

const campaignsPreview = {
  summary: {
    campaigns: 5,
    visitors: 80,
    views: 282,
    conversions: 44,
  },
  rows: [
    {
      name: "founder-post",
      source: "x",
      medium: "social",
      visitors: 42,
      views: 76,
      conversions: 8,
    },
    {
      name: "privacy-analytics",
      source: "google",
      medium: "organic",
      visitors: 37,
      views: 59,
      conversions: 10,
    },
    {
      name: "launch-week",
      source: "producthunt",
      medium: "referral",
      visitors: 35,
      views: 55,
      conversions: 7,
    },
    {
      name: "agency-bundle",
      source: "newsletter",
      medium: "email",
      visitors: 33,
      views: 49,
      conversions: 14,
    },
    {
      name: "launch-day",
      source: "x",
      medium: "social",
      visitors: 34,
      views: 43,
      conversions: 5,
    },
  ],
};
---

<section class="pt-8">
  <Wrapper class="py-20">
    <div class="max-w-4xl">
      <SectionIntro
        title="Trace every UTM campaign back to real actions."
        description="See campaign visitors, views, sources, and mediums in the same dashboard language as the rest of your traffic reports."
      />
    </div>
    <div class="group relative mt-8 overflow-hidden p-4 lg:p-12">
      <Image
        src={paintOne}
        alt=""
        aria-hidden="true"
        loading="lazy"
        decoding="async"
        height={2000}
        width={2000}
        class="absolute inset-0 size-full bg-cover object-cover"
      />

      <div class="relative z-10">
        <AnimatedPanelReveal
          client:load
          trigger="scroll"
          mask={false}
          end="bottom 42%"
          className="transition-transform duration-300 ease-out group-hover:-translate-y-0.5 motion-reduce:transform-none motion-reduce:transition-none"
        >
          <CampaignsDashboardPreview client:load campaigns={campaignsPreview} />
        </AnimatedPanelReveal>
      </div>
    </div>
  </Wrapper>
</section>
