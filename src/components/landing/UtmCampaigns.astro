---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import CampaignsDashboardPreview from "@/components/landing/dashboard/campaigns-dashboard-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";

const campaignsPreview = {
  summary: {
    campaigns: 5,
    visitors: 80,
    views: 282,
    conversions: 44,
    orders: 0,
    revenue: "0",
  },
  rows: [
    {
      name: "founder-post",
      source: "x",
      medium: "social",
      visitors: 42,
      views: 76,
      conversions: 8,
      orders: 0,
      revenue: "0",
    },
    {
      name: "privacy-analytics",
      source: "google",
      medium: "organic",
      visitors: 37,
      views: 59,
      conversions: 10,
      orders: 0,
      revenue: "0",
    },
    {
      name: "launch-week",
      source: "producthunt",
      medium: "referral",
      visitors: 35,
      views: 55,
      conversions: 7,
      orders: 0,
      revenue: "0",
    },
    {
      name: "agency-bundle",
      source: "newsletter",
      medium: "email",
      visitors: 33,
      views: 49,
      conversions: 14,
      orders: 0,
      revenue: "0",
    },
    {
      name: "launch-day",
      source: "x",
      medium: "social",
      visitors: 34,
      views: 43,
      conversions: 5,
      orders: 0,
      revenue: "0",
    },
  ],
};
---

<section class="pt-8">
  <Wrapper
    class="bg-chart-6/5 dark:bg-chart-6/15 border-chart-6/15 rounded-xl border border-dashed py-20"
  >
    <div class="mx-auto max-w-4xl">
      <SectionIntro
        title="Trace every UTM campaign back to real actions."
        description="See campaign visitors, conversions, sources, mediums, and custom events in the same dashboard language as the rest of your traffic reports."
      />

      <div class="group mt-8">
        <AnimatedPanelReveal
          client:load
          trigger="scroll"
          mask={false}
          end="bottom 42%"
          className="transition-transform duration-300 ease-out group-hover:-translate-y-0.5 motion-reduce:transform-none motion-reduce:transition-none"
        >
          <CampaignsDashboardPreview client:load campaigns={campaignsPreview} />
        </AnimatedPanelReveal>
      </div>
    </div>
  </Wrapper>
</section>
