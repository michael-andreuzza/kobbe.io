---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import FunnelsDashboardPreview from "@/components/landing/dashboard/funnels-dashboard-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";

const funnelPreview = {
  name: "Marketing signup",
  completed: 39,
  conversionRate: 0.52,
  steps: [
    { label: "/", visitors: 75, conversionRate: 1, dropoffRate: 0 },
    {
      label: "/pricing",
      visitors: 64,
      conversionRate: 0.853,
      dropoffRate: 0.147,
    },
    {
      label: "signup",
      visitors: 39,
      conversionRate: 0.609,
      dropoffRate: 0.391,
    },
  ],
};
---

<section class="pt-8">
  <Wrapper class="py-20">
    <div class="mx-auto max-w-4xl text-center">
      <SectionIntro
        title="See where visitors continue or drop off."
        description="Build funnels from pages and custom events, then inspect conversion, drop-off, and step-level detail with the same app dashboard view."
      />
    </div>
    <div class="relative mt-8">
      <AnimatedPanelReveal client:load trigger="scroll" mask={false}>
        <FunnelsDashboardPreview client:load funnel={funnelPreview} />
      </AnimatedPanelReveal>
    </div>
  </Wrapper>
</section>
