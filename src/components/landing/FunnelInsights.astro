---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import FunnelsDashboardPreview from "@/components/landing/dashboard/funnels-dashboard-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";

const funnelPreview = {
  name: "Trial signup",
  completed: 236,
  conversionRate: 0.38,
  steps: [
    { label: "Visited pricing", visitors: 1840, conversionRate: 1 },
    {
      label: "Opened signup",
      visitors: 902,
      conversionRate: 0.49,
      dropoffRate: 0.51,
    },
    {
      label: "Created workspace",
      visitors: 418,
      conversionRate: 0.46,
      dropoffRate: 0.54,
    },
    {
      label: "Installed tracker",
      visitors: 236,
      conversionRate: 0.56,
      dropoffRate: 0.44,
    },
  ],
};
---

<section>
  <Wrapper class="py-20">
    <SectionIntro
      title="See where visitors continue or drop off."
      description="Build funnels from pages and custom events, then inspect conversion, drop-off, and step-level detail with the same app dashboard view."
    />

    <div class="group mt-8">
      <AnimatedPanelReveal
        client:load
        trigger="scroll"
        end="bottom 42%"
        className="transition-transform duration-300 ease-out group-hover:-translate-y-0.5 motion-reduce:transform-none motion-reduce:transition-none"
      >
        <FunnelsDashboardPreview client:load funnel={funnelPreview} />
      </AnimatedPanelReveal>
    </div>
  </Wrapper>
</section>
