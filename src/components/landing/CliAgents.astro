---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import CliAgentsPanel from "@/components/landing/cli-agents-panel";
import SectionIntro from "@/components/landing/SectionIntro.astro";
import { Image } from "astro:assets";
import claudeLogo from "@/images/brands/claude.svg";
import codexLogo from "@/images/brands/codex.svg";
import copilotLogo from "@/images/brands/copilot.svg";
import cursorLogo from "@/images/brands/cursor.svg";
import opencodeLogo from "@/images/brands/opencode.svg";
import rooCodeLogo from "@/images/brands/roo code.svg";
import windsurfLogo from "@/images/brands/windsurf.svg";
import zedLogo from "@/images/brands/zed.svg";

const codeEditors = [
  { name: "Cursor", logo: cursorLogo },
  { name: "Claude Code", logo: claudeLogo },
  { name: "Codex", logo: codexLogo },
  { name: "GitHub Copilot", logo: copilotLogo },
  { name: "Zed", logo: zedLogo },
  { name: "OpenCode", logo: opencodeLogo },
  { name: "Roo Code", logo: rooCodeLogo },
  { name: "Windsurf", logo: windsurfLogo },
];
---

<section>
  <Wrapper class="py-20">
    <SectionIntro
      title="CLI access, with MCP built in."
      description="Install one CLI to inspect analytics from your terminal, then run the same package in MCP mode so compatible editors and agents can query Kobbe for you."
    />
    <div class="mt-8">
      <span class="sr-only">Works with MCP-compatible tools, including:</span>
      <div
        class="flex flex-wrap items-center gap-x-4 gap-y-2"
        aria-label="Supported code editors and agents"
      >
        {
          codeEditors.map((editor) => (
            <span>
              <Image
                src={editor.logo}
                alt={`${editor.name} logo`}
                class="size-6 rounded object-contain grayscale transition-all duration-300 hover:grayscale-0"
                loading="lazy"
              />
              <span class="sr-only">{editor.name}</span>
            </span>
          ))
        }
      </div>
    </div>
    <div class="group mt-8">
      <AnimatedPanelReveal
        client:load
        trigger="scroll"
        end="bottom 42%"
        className="transition-transform duration-300 ease-out group-hover:-translate-y-0.5 motion-reduce:transform-none motion-reduce:transition-none"
      >
        <div class="bg-muted overflow-hidden p-8 pb-0 lg:p-32 lg:pb-0">
          <CliAgentsPanel client:load />
        </div>
      </AnimatedPanelReveal>
    </div>
  </Wrapper>
</section>
