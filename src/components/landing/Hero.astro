---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import HeroDashboardPreview from "@/components/landing/hero-dashboard-preview";
import HeroShaderBackground from "@/components/landing/hero-shader-background";
import { buttonVariants } from "@/components/ui/button";
import SectionIntro from "@/components/landing/SectionIntro.astro";
import { pricingTrialDays } from "@/components/sections/pricing/pricing-tiers";
---

<section>
  <Wrapper variant="default" class="pt-20 pb-20 lg:pt-28">
    <div class="mx-auto max-w-2xl text-center">
      <SectionIntro
        title="Privacy-friendly analytics with traffic and revenue in one place."
        description="Pages, sources, funnels, conversions, and revenue attribution. Private by default. Set up in seconds."
      />
      <div class="mx-auto mt-4 flex w-fit flex-wrap gap-2">
        <a
          href="#pricing"
          data-kobbe-event="Hero - start trial"
          class={buttonVariants({ variant: "default", size: "xs" })}
        >
          Start a {pricingTrialDays}-day free trial
        </a>
        <a
          href="https://app.kobbe.io/demo/kobbe-studio"
          target="_blank"
          rel="noopener noreferrer"
          data-kobbe-event="Hero - see demo"
          class={buttonVariants({ variant: "outline", size: "xs" })}
        >
          See the demo
        </a>
      </div>
    </div>
    <div class="relative mt-12 h-200 overflow-hidden bg-[#faf5ff] p-4 lg:p-12">
      <HeroShaderBackground client:load />

      <div class="relative z-10">
        <HeroDashboardPreview client:load />
      </div>
    </div>
    <ul
      class="text-foreground font-display mx-auto mt-8 flex w-fit flex-wrap gap-2 text-center text-2xl"
    >
      <li>1.8KB default tracker gzip</li>
      <li aria-hidden="true" class="text-muted-foreground">·</li>
      <li>Traffic + revenue</li>
      <li aria-hidden="true" class="text-muted-foreground">·</li>
      <li>0 raw IPs stored</li>
    </ul>
  </Wrapper>
</section>
