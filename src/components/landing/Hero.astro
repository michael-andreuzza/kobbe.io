---
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import HeroDashboardPreview from "@/components/landing/hero-dashboard-preview";
import { buttonVariants } from "@/components/ui/button";
---

<section>
  <Wrapper
    variant="default"
    class="bg-chart-1/5 dark:bg-chart-1/15 border-chart-1/15 rounded-xl border border-dashed pt-20 pb-20 lg:pt-28"
  >
    <div class="text-balanc max-w-md lg:mx-auto lg:text-center">
      <Text
        tag="h1"
        variant="displaySM"
        class="text-foreground font-display text-balance"
      >
        Privacy-friendly and cookie-less analytics for your website.
      </Text>
      <Text
        tag="p"
        variant="textSM"
        class="text-muted-foreground mt-4 font-medium"
      >
        See traffic, pages, referrers, locations, devices, funnels, and revenue
        without cookies, raw IP storage, or invasive tracking. Manage with CLI
        or AI agents. — Set up in seconds.
      </Text>

      <div class="mt-4 flex w-fit flex-wrap gap-2 lg:mx-auto">
        <a
          href="#pricing"
          data-kobbe-event="Hero — start trial"
          class={buttonVariants({ variant: "default", size: "xs" })}
        >
          Start a 3-day free trial
        </a>
        <a
          href="https://app.kobbe.io/demo/kobbe-studio"
          target="_blank"
          rel="noopener noreferrer"
          data-kobbe-event="Hero — see demo"
          class={buttonVariants({ variant: "outline", size: "xs" })}
        >
          See the demo
        </a>
      </div>
    </div>
    <div class="mt-8"><HeroDashboardPreview client:load /></div>
    <ul
      class="text-foreground mx-auto mt-8 flex w-fit flex-wrap gap-2 text-center text-sm font-semibold uppercase"
    >
      <li>1.8KB default tracker gzip</li>

      — <li>0 analytics cookies</li>
      —
      <li>0 raw IPs stored</li>
    </ul>
  </Wrapper>
</section>
