---
import Text from "@/components/foundations/elements/Text.astro";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import HeroDashboardPreview from "@/components/landing/hero-dashboard-preview";
---

<section>
  <Wrapper variant="default" class="pt-20 pb-20 lg:pt-28">
    <div class="max-w-xl text-balance">
      <Text
        tag="h1"
        variant="displaySM"
        class="text-foreground font-medium tracking-tight"
      >
        Privacy-friendly and cookie-less analytics for your website.
      </Text>
      <div class="mt-24 lg:mt-32">
        <Text
          tag="p"
          variant="textBase"
          class="text-muted-foreground mt-2 font-medium"
        >
          See traffic, pages, referrers, locations, devices, funnels, and
          revenue without cookies, raw IP storage, or invasive tracking. Manage
          with CLI or AI agents. <br /> — Set up in seconds.
        </Text>

        <a
          href="https://app.kobbe.io/demo/kobbe-studio"
          target="_blank"
          rel="noopener noreferrer"
          data-kobbe-event="Hero — see demo"
          class="text-foreground hover:text-muted-foreground mt-8 flex text-sm font-semibold uppercase"
        >
          See the demo
        </a>
      </div>
    </div>
    <div class="mt-8"><HeroDashboardPreview client:load /></div>
    <ul
      class="text-foreground flex flex-wrap gap-2 text-sm font-semibold uppercase mt-8 text-center w-fit mx-auto"
    >
      <li>1.8KB default tracker gzip</li>

      — <li>0 analytics cookies</li>
      —
      <li>0 raw IPs stored</li>
    </ul>
  </Wrapper>
</section>
