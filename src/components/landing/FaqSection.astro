---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import SectionIntro from "@/components/landing/SectionIntro.astro";
import { PricingFaq } from "@/components/sections/pricing/pricing-faq";
---

<section id="faq" aria-labelledby="faq-heading" class="pt-8">
  <Wrapper
    variant="default"
    class="py-20"
  >
    <div class="mx-auto max-w-2xl">
      <SectionIntro
        id="faq-heading"
        title="FAQ"
        description="Quick answers about plans, trials, and usage."
      />
      <PricingFaq client:load className="mt-10" headingId="faq-heading" />
    </div>
  </Wrapper>
</section>
