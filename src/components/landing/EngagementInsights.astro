---
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import { AnimatedPanelReveal } from "@/components/landing/animated-panel-reveal";
import InsightsDashboardPreview from "@/components/landing/dashboard/insights-dashboard-preview";
import SectionIntro from "@/components/landing/SectionIntro.astro";

const engagementInsightsPoints = [
  {
    title: "Compare engagement KPIs",
    description:
      "Average daily visitors, single-visit share, custom events, and core traffic metrics for the selected range.",
  },
  {
    title: "Review breakdowns together",
    description:
      "Top sources, countries, devices, browsers, pages, and converting events in one Insights view.",
  },
  {
    title: "Find conversion peaks",
    description:
      "The conversion peak heatmap shows when custom events happen most often by day and hour.",
  },
];
---

<section class="pt-8">
  <Wrapper class="py-20">
    <div class="mx-auto max-w-3xl text-center">
      <SectionIntro
        title="See when visitors convert."
        description="Open Insights for engagement KPIs, ranked breakdown tables, and a day-by-hour conversion peak heatmap without leaving the dashboard."
      />
    </div>
    <div class="relative mt-8">
      <AnimatedPanelReveal client:load trigger="scroll" mask={false}>
        <InsightsDashboardPreview client:load />
      </AnimatedPanelReveal>
    </div>

    <div class="mt-8 grid gap-4 text-balance sm:grid-cols-3 lg:text-center">
      {
        engagementInsightsPoints.map((point) => (
          <div data-kobbe-stagger>
            <h3 class="text-foreground text-base font-medium">{point.title}</h3>
            <p class="text-muted-foreground mt-1 text-sm font-medium">
              {point.description}
            </p>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
