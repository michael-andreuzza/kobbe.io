---
type DocsLinkListItem = {
  title: string;
  href: string;
  logo?: {
    src: string;
    alt: string;
  };
};

type DocsLinkListSection = {
  title: string;
  items: DocsLinkListItem[];
};

interface Props {
  sections: DocsLinkListSection[];
  showLogos?: boolean;
  className?: string;
}

const { sections, showLogos = false, className = "mt-8" } = Astro.props;
---

<div class:list={["not-prose space-y-8", className]}>
  {
    sections.map((section) => (
      <section>
        <h2 class="text-foreground text-xl font-semibold tracking-tight">
          {section.title}
        </h2>
        <div class="mt-3 grid gap-2 sm:grid-cols-2">
          {section.items.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-muted-foreground hover:text-foreground text-sm font-medium transition-colors",
                showLogos && "flex items-center gap-2",
              ]}
            >
              {showLogos ? (
                <span class="flex size-5 shrink-0 items-center justify-center">
                  {item.logo ? (
                    <img
                      src={item.logo.src}
                      alt={item.logo.alt}
                      class="size-4 rounded-[0.2rem] object-contain"
                      loading="lazy"
                    />
                  ) : (
                    <span class="text-muted-foreground text-xs">
                      {item.title.slice(0, 1)}
                    </span>
                  )}
                </span>
              ) : null}
              <span>{item.title}</span>
            </a>
          ))}
        </div>
      </section>
    ))
  }
</div>
