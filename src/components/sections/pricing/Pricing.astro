---
import { getImage } from "astro:assets";

import { PricingSection } from "@/components/sections/pricing/pricing-section";
import Wrapper from "@/components/foundations/containers/Wrapper.astro";
import SectionIntro from "@/components/landing/SectionIntro.astro";
import { pricingTrialDays } from "@/components/sections/pricing/pricing-tiers";
import paintOne from "@/images/assets/paint-one.png";

interface Props {
  headingTag?: "h1" | "h2";
}

const appBaseUrl = "https://app.kobbe.io";
const { headingTag = "h2" } = Astro.props;

const paintBackground = await getImage({
  src: paintOne,
  width: paintOne.width,
  quality: 85,
});
---

<section id="pricing" aria-labelledby="pricing-heading" class="pt-8">
  <Wrapper variant="default" class="py-20">
    <div class="mx-auto min-w-0">
      <div class="mx-auto max-w-2xl text-center">
        <SectionIntro
          id="pricing-heading"
          tag={headingTag}
          title="Simple usage-based pricing."
          description={`Start with a ${pricingTrialDays}-day trial. No credit card required. Every volume tier includes the same features — you only pay for more events.`}
        />
      </div>

      <div class="mt-10 min-w-0">
        <PricingSection
          client:load
          appBaseUrl={appBaseUrl}
          paintSrc={paintBackground.src}
          paintWidth={paintOne.width}
          paintHeight={paintOne.height}
        />
      </div>
    </div>
  </Wrapper>
</section>
