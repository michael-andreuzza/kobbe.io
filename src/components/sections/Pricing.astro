---
/** Polar-backed tiers; amounts are marketing copy (check app for source of truth). */
const plans = [
  {
    name: "Starter",
    monthlyPrice: "9",
    yearlyPrice: "90",
    yearlyMonthlyEquivalent: "7.50",
    description: "For one site or a focused side project.",
    checkouts: {
      monthly:
        "https://buy.polar.sh/polar_cl_xxRB88wwzrN4RQaeo7hyJ11ecalyuLbeoTTLt1KIgo1",
      yearly:
        "https://buy.polar.sh/polar_cl_LqxdB8lO9anLqYIfVadxDDw4tp1sK0J5Y98Dy2NCe07",
    },
    features: [
      "1 website",
      "50k monthly events",
      "180 days data retention",
      "Cookie-free analytics",
      "Realtime dashboard",
      "Events, funnels, and revenue attribution",
      "Shareable dashboard links",
      "CSV export",
    ],
    cta: "Get started",
    emphasis: false,
  },
  {
    name: "Growth",
    monthlyPrice: "19",
    yearlyPrice: "190",
    yearlyMonthlyEquivalent: "15.83",
    description: "For multiple sites and growing traffic.",
    checkouts: {
      monthly:
        "https://buy.polar.sh/polar_cl_hnt46OFzo4f9t3GLjTBhPR3aPcIrWNg6ZMSDQ3Y6Z99",
      yearly:
        "https://buy.polar.sh/polar_cl_IvnnLzyVd1Z1oHxVFWClZciXTrNeQH9ZjsRTN2dfIlT",
    },
    features: [
      "Everything in Starter",
      "10 websites",
      "500k monthly events",
      "180 days data retention",
      "One workspace for all sites",
      "AI referrer insights",
      "Bot and spam filtering",
      "Priority room to grow",
    ],
    cta: "Get started",
    emphasis: true,
  },
] as const;
---

<section class="border-border/60 bg-surface border-t" id="pricing" aria-labelledby="pricing-heading">
  <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
    <p
      class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
    >
      Pricing
    </p>
    <h2
      id="pricing-heading"
      class="text-foreground mt-3 max-w-[40ch] text-2xl font-semibold tracking-tight sm:text-3xl"
    >
      Simple plans. No free tier.
    </h2>
    <div
      class="mt-4 flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between"
    >
      <p class="text-muted-foreground max-w-[60ch] text-base/7">
        Pay monthly, or choose yearly and get two months free. Checkout is
        handled securely by Polar.
      </p>

      <div
        class="border-border/70 bg-card inline-flex w-fit rounded-lg border p-1 shadow-xs"
        role="group"
        aria-label="Billing period"
      >
        <button
          type="button"
          class="bg-foreground text-background rounded-md px-3 py-1.5 text-sm font-medium shadow-xs transition-colors"
          data-billing-toggle="monthly"
          aria-pressed="true"
        >
          Monthly
        </button>
        <button
          type="button"
          class="text-muted-foreground hover:text-foreground rounded-md px-3 py-1.5 text-sm font-medium transition-colors"
          data-billing-toggle="yearly"
          aria-pressed="false"
        >
          Yearly
          <span class="ml-1 text-xs">2 months free</span>
        </button>
      </div>
    </div>

    <div
      data-pricing-section
      data-billing-period="monthly"
      class="mt-12 grid gap-6 lg:mt-16 lg:grid-cols-2 lg:gap-8"
    >
      {
        plans.map((plan) => (
          <div
            class:list={[
              "border-border/80 bg-card flex flex-col rounded-xl border p-6 shadow-xs lg:p-8",
              plan.emphasis &&
                "ring-primary/25 border-primary/30 relative ring-2",
            ]}
          >
            {plan.emphasis ? (
              <p class="text-primary absolute -top-3 left-6 rounded-md bg-surface px-2 text-xs font-medium">
                Most popular
              </p>
            ) : null}
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="text-foreground text-lg font-semibold">{plan.name}</h3>
              <div class="text-right">
                <p
                  class="text-foreground text-2xl font-semibold tabular-nums"
                  data-period="monthly"
                >
                  <span class="text-muted-foreground text-base font-normal">
                    $
                  </span>
                  {plan.monthlyPrice}
                  <span class="text-muted-foreground text-sm font-normal">
                    {" "}
                    / month
                  </span>
                </p>
                <p
                  class="text-foreground text-2xl font-semibold tabular-nums"
                  data-period="yearly"
                >
                  <span class="text-muted-foreground text-base font-normal">
                    $
                  </span>
                  {plan.yearlyPrice}
                  <span class="text-muted-foreground text-sm font-normal">
                    {" "}
                    / year
                  </span>
                </p>
                <p
                  class="text-muted-foreground mt-1 text-xs tabular-nums"
                  data-period="yearly"
                >
                  ${plan.yearlyMonthlyEquivalent}/mo, billed yearly
                </p>
              </div>
            </div>
            <p class="text-muted-foreground mt-3 text-sm/6">{plan.description}</p>
            <ul
              class="text-muted-foreground mt-6 flex flex-1 list-inside list-disc flex-col gap-1.5 text-sm/[1.45] marker:text-foreground/45 sm:gap-2 sm:text-sm/6"
            >
              {plan.features.map((line) => (
                <li>
                  <span class="-ml-0.5">{line}</span>
                </li>
              ))}
            </ul>
            <a
              href={plan.checkouts.monthly}
              data-checkout-monthly={plan.checkouts.monthly}
              data-checkout-yearly={plan.checkouts.yearly}
              class:list={[
                "mt-8 inline-flex w-full items-center justify-center rounded-lg px-4 py-2.5 text-sm font-medium shadow-xs transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring",
                plan.emphasis
                  ? "bg-primary text-primary-foreground hover:bg-primary/90"
                  : "bg-secondary text-secondary-foreground hover:bg-secondary/90 border-border border",
              ]}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>

    <p class="text-muted-foreground mx-auto mt-10 max-w-[52ch] text-center text-sm/6">
      Prices shown in USD. Yearly plans are billed upfront. Need more than
      Growth?{" "}
      <a
        href="mailto:support@kobbe.io"
        class="text-foreground underline-offset-4 hover:underline"
      >
        Contact us
      </a>
      {" "}for volume or teams.
    </p>
  </div>
</section>

<style>
  [data-pricing-section][data-billing-period="monthly"]
    [data-period="yearly"],
  [data-pricing-section][data-billing-period="yearly"]
    [data-period="monthly"] {
    display: none;
  }
</style>

<script>
  type BillingPeriod = "monthly" | "yearly";
  type KobbeWindow = Window &
    typeof globalThis & {
      kobbe?: {
        attributionId?: string;
        getAttributionId?: () => string | undefined;
      };
    };

  const pricingSection = document.querySelector("[data-pricing-section]");
  const billingToggles = Array.from(
    document.querySelectorAll("[data-billing-toggle]"),
  );

  function checkoutHrefWithAttribution(href: string) {
    const kobbe = (window as KobbeWindow).kobbe;
    const attributionId =
      kobbe?.getAttributionId?.() ?? kobbe?.attributionId;

    if (!attributionId) return href;

    try {
      const url = new URL(href, window.location.href);
      url.searchParams.set("reference_id", attributionId);
      return url.toString();
    } catch {
      return href;
    }
  }

  function updateCheckoutHref(link: Element, period: BillingPeriod) {
    const href =
      period === "yearly"
        ? link.getAttribute("data-checkout-yearly")
        : link.getAttribute("data-checkout-monthly");

    if (href) {
      link.setAttribute("href", checkoutHrefWithAttribution(href));
    }
  }

  function setBillingPeriod(period: "monthly" | "yearly") {
    if (!pricingSection) return;

    pricingSection.setAttribute("data-billing-period", period);

    for (const toggle of billingToggles) {
      const active = toggle.getAttribute("data-billing-toggle") === period;
      toggle.setAttribute("aria-pressed", String(active));
      toggle.classList.toggle("bg-foreground", active);
      toggle.classList.toggle("text-background", active);
      toggle.classList.toggle("shadow-xs", active);
      toggle.classList.toggle("text-muted-foreground", !active);
      toggle.classList.toggle("hover:text-foreground", !active);
    }

    for (const link of pricingSection.querySelectorAll("[data-checkout-monthly]")) {
      updateCheckoutHref(link, period);
    }
  }

  for (const toggle of billingToggles) {
    toggle.addEventListener("click", () => {
      const period = toggle.getAttribute("data-billing-toggle");
      if (period === "monthly" || period === "yearly") {
        setBillingPeriod(period);
      }
    });
  }

  if (pricingSection) {
    const initialPeriod =
      pricingSection.getAttribute("data-billing-period") === "yearly"
        ? "yearly"
        : "monthly";

    for (const link of pricingSection.querySelectorAll("[data-checkout-monthly]")) {
      updateCheckoutHref(link, initialPeriod);
      link.addEventListener("click", () => {
        const period =
          pricingSection.getAttribute("data-billing-period") === "yearly"
            ? "yearly"
            : "monthly";
        updateCheckoutHref(link, period);
      });
    }
  }
</script>
